<footer class="footer full-width" role="contentinfo">
  {{- '<!-- Animated wave divider top -->' -}}
  <div class="footer__wave-wrap" aria-hidden="true">
    <svg
      class="footer__wave footer__wave--back"
      viewBox="0 0 1440 90"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="none"
    >
      <path d="M0 45 C240 0, 480 90, 720 45 S1200 0, 1440 45 L1440 90 L0 90 Z" fill="var(--footer-wave-back)"/>
    </svg>
    <svg
      class="footer__wave footer__wave--mid"
      viewBox="0 0 1440 90"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="none"
    >
      <path d="M0 55 C180 10, 360 90, 540 55 S900 15, 1080 55 S1350 80, 1440 55 L1440 90 L0 90 Z" fill="var(--footer-wave-mid)"/>
    </svg>
    <svg
      class="footer__wave footer__wave--front"
      viewBox="0 0 1440 90"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      preserveAspectRatio="none"
    >
      <path d="M0 62 C120 30, 300 90, 480 62 S750 25, 960 62 S1250 85, 1440 62 L1440 90 L0 90 Z" fill="var(--footer-bg)"/>
    </svg>
  </div>

  {{- '<!-- Row 1: Main Content -->' -}}
  <div class="footer__main">
    <div class="footer__inner">
      <div class="footer__grid">
        {{- '<!-- Col 1: Brand -->' -}}
        <div class="footer__col footer__col--brand">
          <div class="footer__logo-wrap">
            {%- if section.settings.logo != blank -%}
              <img
                class="footer__logo"
                src="{{ section.settings.logo | image_url: width: 180 }}"
                alt="{{ shop.name }}"
                width="180"
                loading="lazy"
                height="auto"
              >
            {%- else -%}
              <span class="footer__shop-name">{{ shop.name }}</span>
            {%- endif -%}
          </div>

          {%- if section.settings.brand_text != blank -%}
            <p class="footer__brand-text">{{ section.settings.brand_text }}</p>
          {%- endif -%}

          <div class="footer__brand-badge">
            <span class="footer__brand-badge-dot"></span>
            {{ section.settings.brand_tagline | default: 'Snacks naturales · Hecho en México' }}
          </div>
        </div>

        {{- '<!-- Col 2: Navigation -->' -}}
        <div class="footer__col footer__col--nav">
          <h3 class="footer__col-heading">
            <span>{{ section.settings.nav_heading | default: 'Explora' }}</span>
          </h3>
          {%- if section.settings.nav_menu != blank -%}
            {%- assign nav_menu = linklists[section.settings.nav_menu] -%}
            {%- if nav_menu != blank -%}
              <ul class="footer__links" role="list">
                {%- for link in nav_menu.links -%}
                  <li class="footer__link-item">
                    <a class="footer__link" href="{{ link.url }}">
                      <span class="footer__link-arrow" aria-hidden="true">→</span>
                      {{ link.title }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          {%- endif -%}
        </div>

        {{- '<!-- Col 3: Support & Legal -->' -}}
        <div class="footer__col footer__col--support">
          <h3 class="footer__col-heading">
            <span>{{ section.settings.support_heading | default: 'Ayuda & Legal' }}</span>
          </h3>
          {%- if section.settings.support_menu != blank -%}
            {%- assign support_menu = linklists[section.settings.support_menu] -%}
            {%- if support_menu != blank -%}
              <ul class="footer__links" role="list">
                {%- for link in support_menu.links -%}
                  <li class="footer__link-item">
                    <a class="footer__link" href="{{ link.url }}">
                      <span class="footer__link-arrow" aria-hidden="true">→</span>
                      {{ link.title }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          {%- else -%}
            {{- '<!-- Fallback static links -->' -}}
            <ul class="footer__links" role="list">
              <li class="footer__link-item">
                <a class="footer__link" href="/policies/refund-policy">
                  <span class="footer__link-arrow" aria-hidden="true">→</span>
                  Devoluciones &amp; Cambios
                </a>
              </li>
              <li class="footer__link-item">
                <a class="footer__link" href="/policies/privacy-policy">
                  <span class="footer__link-arrow" aria-hidden="true">→</span>
                  Política de Privacidad
                </a>
              </li>
              <li class="footer__link-item">
                <a class="footer__link" href="/pages/atencion-al-cliente">
                  <span class="footer__link-arrow" aria-hidden="true">→</span>
                  Atención al Cliente
                </a>
              </li>
            </ul>
          {%- endif -%}
        </div>
      </div>
      {{- '<!-- /grid -->' -}}
    </div>
  </div>

  {{- '<!-- Row 2: Bottom bar -->' -}}
  <div class="footer__bottom">
    <div class="footer__bottom-inner">
      {{- '<!-- Payments -->' -}}
      {%- if section.settings.show_payment_icons -%}
        <div class="footer__payment" role="group" aria-label="Métodos de pago aceptados">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {{- '<!-- Socials -->' -}}
      <div class="footer__social" role="list" aria-label="Redes sociales">
        {%- if section.settings.instagram_url != blank -%}
          <a
            class="footer__social-btn footer__social-btn--instagram"
            href="{{ section.settings.instagram_url }}"
            target="_blank"
            rel="noopener noreferrer"
            role="listitem"
            aria-label="Instagram"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="17"
              height="17"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if section.settings.tiktok_url != blank -%}
          <a
            class="footer__social-btn footer__social-btn--tiktok"
            href="{{ section.settings.tiktok_url }}"
            target="_blank"
            rel="noopener noreferrer"
            role="listitem"
            aria-label="TikTok"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if section.settings.facebook_url != blank -%}
          <a
            class="footer__social-btn footer__social-btn--facebook"
            href="{{ section.settings.facebook_url }}"
            target="_blank"
            rel="noopener noreferrer"
            role="listitem"
            aria-label="Facebook"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
        {%- endif -%}
      </div>

      {{- '<!-- Branding / Copyright -->' -}}
      <p class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }}
        <strong>{{ shop.name }}</strong>.
        {{ section.settings.copyright_extra | default: 'Hecho con amor en México.' }}
      </p>
    </div>
  </div>
</footer>

{% stylesheet %}
  /* ── Design Tokens ──────────────────────────────────── */
  .footer {
    --footer-bg: #0d2b32;
    --footer-wave-back: #0a3a44;
    --footer-wave-mid: #0b3340;
    --footer-surface: rgba(255, 255, 255, 0.06);
    --footer-border: rgba(255, 255, 255, 0.12);
    --footer-text: rgba(255, 255, 255, 0.8);
    --footer-text-muted: rgba(255, 255, 255, 0.45);
    --footer-accent: var(--color-accent, #f86d4e);
    --footer-teal: var(--color-secondary, #0296b4);
  }

  /* ── Base ───────────────────────────────────────────── */
  .footer {
    position: relative;
    background: var(--footer-bg);
    overflow: hidden;
  }

  /* ── Wave stack ─────────────────────────────────────── */
  .footer__wave-wrap {
    position: relative;
    width: 100%;
    height: 90px;
    line-height: 0;
    display: block;
    overflow: hidden;
  }

  .footer__wave {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* back wave: slow drift */
  .footer__wave--back {
    animation: wave-drift 14s ease-in-out infinite alternate;
    transform-origin: center bottom;
  }

  /* mid wave: medium speed, opposite phase */
  .footer__wave--mid {
    animation: wave-drift 9s ease-in-out infinite alternate-reverse;
    transform-origin: center bottom;
  }

  /* front wave: fastest, sharpest */
  .footer__wave--front {
    animation: wave-drift 6s ease-in-out infinite alternate;
    transform-origin: center bottom;
  }

  @keyframes wave-drift {
    0% {
      transform: scaleX(1) translateX(0);
    }
    100% {
      transform: scaleX(1.04) translateX(-2%);
    }
  }

  /* ── Row 1: Main ────────────────────────────────────── */
  .footer__main {
    position: relative;
  }

  .footer__inner {
    width: min(var(--page-width), calc(100% - (var(--page-margin) * 2)));
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 3.5rem) 0 clamp(2rem, 4vw, 3rem);
  }

  /* ── Three-column grid ──────────────────────────────── */
  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  @media screen and (min-width: 640px) {
    .footer__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem 3rem;
    }
    .footer__col--brand {
      grid-column: 1 / -1;
    }
  }

  @media screen and (min-width: 960px) {
    .footer__grid {
      grid-template-columns: 1.7fr 1fr 1.1fr;
      gap: 0 3.5rem;
      align-items: start;
    }
    .footer__col--brand {
      grid-column: auto;
    }
  }

  /* ── Col 1: Brand ───────────────────────────────────── */
  .footer__logo-wrap {
    margin-bottom: 1rem;
  }

  .footer__logo {
    max-height: 6rem;
    width: auto;
    display: block;
  }

  .footer__shop-name {
    font-family: var(--font-heading-family), sans-serif;
    font-size: 1.75rem;
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.03em;
    line-height: 1;
    text-transform: uppercase;
  }

  .footer__brand-text {
    margin: 0 0 1.25rem;
    font-size: 0.875rem;
    line-height: 1.7;
    color: var(--footer-text);
    max-width: 32ch;
  }

  /* Chunky badge — neo-brutalist feel */
  .footer__brand-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    background: var(--footer-teal);
    color: #fff;
    font-family: var(--font-heading-family), sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.35rem 0.9rem;
    border-radius: 1rem;
    box-shadow: 3px 3px 0 rgba(0, 0, 0, 0.35);
  }

  .footer__brand-badge-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #fff;
    flex-shrink: 0;
    animation: badge-pulse 2.4s ease-in-out infinite;
  }

  @keyframes badge-pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(0.7);
    }
  }

  /* ── Col headings ───────────────────────────────────── */
  .footer__col-heading {
    margin: 0 0 1.25rem;
    font-family: var(--font-heading-family), sans-serif;
    font-size: 0.8rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* ── Link lists (shared by nav & support cols) ──────── */
  .footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .footer__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    color: var(--footer-text);
    text-decoration: none;
    transition: color 0.18s ease, gap 0.2s ease;
  }

  .footer__link-arrow {
    color: var(--footer-accent);
    font-size: 0.8rem;
    font-weight: 700;
    transition: transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
    display: inline-block;
  }

  .footer__link:hover {
    color: #fff;
    gap: 0.65rem;
  }

  .footer__link:hover .footer__link-arrow {
    transform: translateX(5px);
  }

  /* ── Row 2: Bottom bar ──────────────────────────────── */
  .footer__bottom {
    position: relative;
    border-top: 2px solid var(--footer-border);
    /* thick border for neo-brutalist edge */
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .footer__bottom-inner {
    width: min(var(--page-width), calc(100% - (var(--page-margin) * 2)));
    margin: 0 auto;
    padding: 1rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
  }

  @media screen and (min-width: 768px) {
    .footer__bottom-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      text-align: left;
      gap: 1.25rem;
    }
  }

  /* ── Payment icons ──────────────────────────────────── */
  .footer__payment {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.4rem;
    justify-content: center;
  }

  @media screen and (min-width: 768px) {
    .footer__payment {
      justify-content: flex-start;
    }
  }

  .footer__payment-icon {
    height: 22px;
    width: auto;
    border-radius: 3px;
    opacity: 0.6;
    transition: opacity 0.2s ease, transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
    filter: brightness(0) invert(1);
  }

  .footer__payment-icon:hover {
    opacity: 1;
    transform: translateY(-2px);
  }

  /* ── Socials (bottom bar) ───────────────────────────── */
  .footer__social {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
  }

  .footer__social-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 4px;
    color: #fff;
    border: 2.5px solid rgba(255, 255, 255, 0.2);
    background: var(--footer-surface);
    transition: transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1), border-color 0.18s ease, background 0.18s ease,
      box-shadow 0.18s ease;
  }

  .footer__social-btn:hover {
    transform: translateY(-5px) scale(1.1);
    border-color: #fff;
    box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.4);
  }

  /* Platform colors on hover */
  .footer__social-btn--instagram:hover {
    background: linear-gradient(135deg, #f9ce34, #ee2a7b, #6228d7);
    border-color: transparent;
  }
  .footer__social-btn--tiktok:hover {
    background: #111;
    border-color: #69c9d0;
  }
  .footer__social-btn--facebook:hover {
    background: #1877f2;
    border-color: transparent;
  }

  /* ── Copyright ──────────────────────────────────────── */
  .footer__copyright {
    margin: 0;
    font-size: 0.78rem;
    color: var(--footer-text-muted);
    line-height: 1.5;
    white-space: nowrap;
  }

  .footer__copyright strong {
    color: var(--footer-text);
    font-weight: 700;
  }
{% endstylesheet %}

{% schema %}
