<section class="newsletter full-width">

  {{- '<!-- Deco blobs -->' -}}
  <div class="newsletter__blob newsletter__blob--1" aria-hidden="true"></div>
  <div class="newsletter__blob newsletter__blob--2" aria-hidden="true"></div>

  {{- '<!-- Deco paw -->' -}}
  <div class="newsletter__deco newsletter__deco--bone-right" aria-hidden="true">
    <svg width="60" height="30" viewBox="0 0 52 26" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="7"  cy="7"  r="6" fill="currentColor" opacity="0.2"/>
      <circle cx="7"  cy="19" r="6" fill="currentColor" opacity="0.2"/>
      <circle cx="45" cy="7"  r="6" fill="currentColor" opacity="0.2"/>
      <circle cx="45" cy="19" r="6" fill="currentColor" opacity="0.2"/>
      <rect x="10" y="10" width="32" height="6" rx="3" fill="currentColor" opacity="0.2"/>
    </svg>
  </div>

  <div class="newsletter__inner">
    {{- '<!-- Envelope deco icon -->' -}}
    <div class="newsletter__icon-wrap" aria-hidden="true">
      <div class="newsletter__icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="20" height="16" x="2" y="4" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </div>
      <div class="newsletter__icon-ring" aria-hidden="true"></div>
    </div>

    {{- '<!-- Copy -->' -}}
    <div class="newsletter__copy">
      {%- if section.settings.heading != blank -%}
        <h2 class="newsletter__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <p class="newsletter__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    {{- '<!-- Form -->' -}}
    {%- form 'customer', id: 'newsletter-form', class: 'newsletter__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input type="hidden" name="contact[accepts_marketing]" value="true">

      <div class="newsletter__field-wrap">
        <label for="newsletter-email" class="newsletter__sr-label">{{ 'general.newsletter.email_label' | t | default: 'Correo electrónico' }}</label>

        <input
          id="newsletter-email"
          class="newsletter__input"
          type="email"
          name="contact[email]"
          value="{% if customer %}{{ customer.email }}{% endif %}"
          placeholder="{{ section.settings.input_placeholder | default: 'tu@correo.com' }}"
          autocomplete="email"
          required
          aria-required="true"
        >

        <button class="newsletter__submit" type="submit" aria-label="{{ section.settings.button_label | default: 'Suscribirse' }}">
          <span class="newsletter__submit-text">{{ section.settings.button_label | default: 'Suscribirse' }}</span>
          <span class="newsletter__submit-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </span>
        </button>
      </div>

      {%- if form.posted_successfully? -%}
        <p class="newsletter__success" role="status">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/>
          </svg>
          {{ section.settings.success_message | default: '¡Listo! Ahora eres parte de la manada. 🐾' }}
        </p>
      {%- endif -%}

      {%- if form.errors -%}
        <p class="newsletter__error" role="alert">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/>
          </svg>
          {{ form.errors | default_errors }}
        </p>
      {%- endif -%}

    {%- endform -%}

    {%- if section.settings.privacy_note != blank -%}
      <p class="newsletter__privacy">{{ section.settings.privacy_note }}</p>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
  /* ── Keyframes ──────────────────────────────────────── */
  @keyframes nl-float-blob {
    0%, 100% { transform: scale(1)   translate(0, 0);      }
    33%       { transform: scale(1.1) translate(8px, -6px); }
    66%       { transform: scale(0.9) translate(-6px, 4px); }
  }

  @keyframes nl-bounce-icon {
    0%, 100% { transform: translateY(0);   }
    40%       { transform: translateY(-7px); }
    60%       { transform: translateY(-4px); }
  }

  @keyframes nl-ring {
    0%   { transform: scale(1);    opacity: 0.55; }
    100% { transform: scale(1.65); opacity: 0;    }
  }

  @keyframes nl-arrow-slide {
    0%, 100% { transform: translateX(0);  }
    50%       { transform: translateX(4px); }
  }

  @keyframes nl-success-in {
    from { opacity: 0; transform: translateY(8px) scale(0.95); }
    to   { opacity: 1; transform: translateY(0)   scale(1);    }
  }

  /* ── Section ────────────────────────────────────────── */
  .newsletter {
    position: relative;
    background: var(--color-secondary, #0296B4);
    overflow: hidden;
  }

  /* ── Morphing blobs ─────────────────────────────────── */
  .newsletter__blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(50px);
    pointer-events: none;
    opacity: 0.25;
  }

  .newsletter__blob--1 {
    width: 280px;
    height: 280px;
    background: var(--color-accent, #F86D4E);
    top: -80px;
    left: -60px;
    animation: nl-float-blob 8s ease-in-out infinite;
  }

  .newsletter__blob--2 {
    width: 220px;
    height: 220px;
    background: var(--color-cream, #FCECC9);
    bottom: -70px;
    right: -40px;
    animation: nl-float-blob 10s ease-in-out infinite 2s;
  }

  /* ── Decos ──────────────────────────────────────────── */
  .newsletter__deco {
    position: absolute;
    pointer-events: none;
    user-select: none;
    color: #fff;
  }


  .newsletter__deco--bone-right {
    right: 2rem;
    top: 1.25rem;
    transform: rotate(8deg);
  }

  /* ── Inner ──────────────────────────────────────────── */
  .newsletter__inner {
    position: relative;
    width: min(var(--page-width), calc(100% - (var(--page-margin) * 2)));
    margin: 0 auto;
    padding: clamp(3.5rem, 7vw, 5rem) 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 560px;
  }

  /* ── Envelope icon ──────────────────────────────────── */
  .newsletter__icon-wrap {
    position: relative;
    width: 5rem;
    height: 5rem;
    flex-shrink: 0;
    animation: nl-bounce-icon 3s ease-in-out infinite;
  }

  .newsletter__icon {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: #fff;
    color: var(--color-secondary, #0296B4);
    border: 2.5px solid #1a1a1a;
    box-shadow: 3px 3px 0px 0px #1a1a1a;
  }

  .newsletter__icon-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid rgba(255,255,255,0.55);
    animation: nl-ring 2.4s ease-out infinite;
  }

  /* ── Copy ───────────────────────────────────────────── */
  .newsletter__copy {
    text-align: center;
  }

  .newsletter__heading {
    margin: 0 0 0.5rem;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: clamp(1.75rem, 4.5vw, 2.5rem);
    color: #fff;
    letter-spacing: -0.01em;
    line-height: 1.15;
  }

  .newsletter__subtext {
    margin: 0;
    font-size: clamp(0.9rem, 2vw, 1.05rem);
    color: rgba(255,255,255,0.8);
    line-height: 1.55;
    max-width: 40ch;
  }

  /* ── Form ───────────────────────────────────────────── */
  .newsletter__form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .newsletter__sr-label {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border-width: 0;
  }

  /* pill wrapper */
  .newsletter__field-wrap {
    display: flex;
    width: 100%;
    background: #fff;
    border: 2.5px solid #1a1a1a;
    border-radius: 999px;
    box-shadow: 5px 5px 0px 0px #1a1a1a;
    overflow: hidden;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .newsletter__field-wrap:focus-within {
    box-shadow: 7px 7px 0px 0px #1a1a1a;
    transform: translateY(-2px);
  }

  .newsletter__input {
    flex: 1;
    border: none;
    outline: none;
    padding: 0.85rem 1.25rem;
    font-size: 1.05rem;
    font-family: var(--font-body-family), 'Nunito Sans', sans-serif;
    color: var(--color-foreground, #333);
    background: transparent;
    min-width: 0;
  }

  .newsletter__input::placeholder {
    color: rgba(51,51,51,0.38);
  }

  .newsletter__submit {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 1.35rem;
    margin: 0.3rem 0.3rem 0.3rem 0;
    background: var(--color-accent, #F86D4E);
    color: #fff;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    border: 2px solid #1a1a1a;
    border-radius: 999px;
    cursor: pointer;
    white-space: nowrap;
    transition: transform 0.2s cubic-bezier(.34,1.56,.64,1),
                background 0.15s ease;
    flex-shrink: 0;
  }

  .newsletter__submit:hover {
    transform: scale(1.05);
    background: #e85a3a;
  }

  .newsletter__submit:hover .newsletter__submit-icon svg {
    animation: nl-arrow-slide 0.5s ease-in-out infinite;
  }

  .newsletter__submit:active {
    transform: scale(0.97);
  }

  /* ── Feedback states ────────────────────────────────── */
  .newsletter__success,
  .newsletter__error {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.1rem;
    border-radius: 0.85rem;
    font-size: 0.9rem;
    font-weight: 600;
    border: 2px solid #1a1a1a;
    animation: nl-success-in 0.35s cubic-bezier(.34,1.56,.64,1) both;
  }

  .newsletter__success {
    background: #fff;
    color: var(--color-secondary, #0296B4);
    box-shadow: 3px 3px 0px 0px #1a1a1a;
  }

  .newsletter__error {
    background: #fff0ee;
    color: var(--color-accent, #F86D4E);
    box-shadow: 3px 3px 0px 0px #1a1a1a;
  }

  /* ── Privacy note ───────────────────────────────────── */
  .newsletter__privacy {
    margin: 0;
    font-size: 0.78rem;
    color: rgba(255,255,255,0.55);
    text-align: center;
    line-height: 1.4;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Únete a la manada"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Recetas nuevas, descuentos exclusivos y tips para tu perro. Sin spam, solo lo bueno."
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Input placeholder",
      "default": "tu@correo.com"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Suscribirse"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "¡Listo! Ahora eres parte de la manada. 🐾"
    },
    {
      "type": "text",
      "id": "privacy_note",
      "label": "Privacy note (optional)",
      "default": "Sin spam. Puedes darte de baja cuando quieras."
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}