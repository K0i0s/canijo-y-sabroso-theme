<section
  class="hero-banner full-width"
  style="--hero-bg: {{ section.settings.bg_color }};"
>
  <div class="hero-banner__inner">
    <div class="hero-banner__media">
      <div class="hero-banner__art">
        <span class="hero-banner__blob hero-banner__blob--main"></span>
        <span class="hero-banner__blob hero-banner__blob--accent"></span>
        <span class="hero-banner__stroke hero-banner__stroke--1"></span>
        <span class="hero-banner__stroke hero-banner__stroke--2"></span>
        <span class="hero-banner__paw hero-banner__paw--1"></span>
        <span class="hero-banner__paw hero-banner__paw--2"></span>
        <span class="hero-banner__paw hero-banner__paw--3"></span>
        <span class="hero-banner__shadow"></span>

        {% if section.settings.image != blank %}
          {{
            section.settings.image
            | image_url: width: 900
            | image_tag:
              class: 'hero-banner__image',
              widths: '360, 520, 720, 900',
              sizes: '(min-width: 990px) 42vw, 78vw',
              loading: 'eager',
              alt: section.settings.heading
          }}
        {% else %}
          <img
            class="hero-banner__image"
            src="{{ 'hero-banner-canijo-y-sabroso.webp' | asset_url }}"
            alt="{{ section.settings.heading | escape }}"
            width="900"
            height="900"
            loading="eager"
          >
        {% endif %}
      </div>
    </div>

    <div class="hero-banner__content">
      <p class="hero-banner__eyebrow">Canijo y Sabroso</p>
      <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>
      <div class="hero-banner__subtext rte">
        <p>{{ section.settings.subtext }}</p>
      </div>

      {% if section.settings.button_text != blank %}
        {% if section.settings.button_url != blank %}
          <a class="hero-banner__cta" href="{{ section.settings.button_url }}">
            {{ section.settings.button_text }}
          </a>
        {% else %}
          <span class="hero-banner__cta hero-banner__cta--static">
            {{ section.settings.button_text }}
          </span>
        {% endif %}
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .hero-banner {
    background: var(--hero-bg);
    overflow: hidden;
  }

  .hero-banner__inner {
    width: min(var(--page-width), calc(100% - (var(--page-margin) * 2)));
    margin: 0 auto;
    display: grid;
    gap: 2rem;
    padding: clamp(1.75rem, 4vw, 2.5rem) 0 clamp(2.5rem, 5vw, 4rem);
  }

  .hero-banner__media {
    order: 1;
  }

  .hero-banner__content {
    order: 2;
    display: grid;
    gap: 1rem;
    align-content: center;
    max-width: 34rem;
  }

  .hero-banner__eyebrow {
    margin: 0;
    color: var(--color-secondary);
    font-family: var(--font-heading-family);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero-banner__heading {
    margin: 0;
    color: var(--color-accent);
    font-weight: 600;
    font-size: clamp(2.45rem, 8vw, 4.4rem);
    line-height: 0.92;
    text-wrap: balance;
  }

  .hero-banner__subtext {
    color: rgba(51, 51, 51, 0.9);
    font-size: clamp(1rem, 2.6vw, 1.15rem);
    line-height: 1.55;
    max-width: 32rem;
  }

  .hero-banner__subtext p {
    margin: 0;
  }

  .hero-banner__cta,
  .hero-banner__cta:visited {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 3.5rem;
    padding: 0.95rem 1.6rem;
    border-radius: 999px;
    background: var(--color-accent);
    color: #fff;
    font-family: var(--font-heading-family);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    box-shadow: 0 14px 24px rgba(248, 109, 78, 0.28);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
  }

  .hero-banner__cta:hover {
    background: var(--color-secondary);
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 16px 26px rgba(2, 150, 180, 0.24);
  }

  .hero-banner__cta--static {
    cursor: default;
  }

  .hero-banner__art {
    position: relative;
    width: min(100%, 30rem);
    margin: 0 auto;
    aspect-ratio: 1 / 1;
  }

  .hero-banner__blob,
  .hero-banner__stroke,
  .hero-banner__paw,
  .hero-banner__shadow {
    position: absolute;
  }

  .hero-banner__blob--main {
    inset: 18% 10% 20% 12%;
    background: rgba(2, 150, 180, 0.23);
    border-radius: 42% 58% 57% 43% / 34% 39% 61% 66%;
  }

  .hero-banner__blob--accent {
    inset: 22% 16% 28% 18%;
    background: rgba(2, 150, 180, 0.72);
    border-radius: 54% 46% 41% 59% / 47% 60% 40% 53%;
    filter: blur(1px);
  }

  .hero-banner__stroke {
    top: 16%;
    left: 7%;
    width: 2.7rem;
    height: 0.32rem;
    border-radius: 999px;
    background: rgba(2, 150, 180, 0.88);
    transform-origin: left center;
  }

  .hero-banner__stroke--1 {
    transform: rotate(42deg);
  }

  .hero-banner__stroke--2 {
    top: 23%;
    left: 4%;
    width: 2.1rem;
    transform: rotate(17deg);
  }

  .hero-banner__paw {
    width: 1.35rem;
    height: 1.35rem;
    background: var(--color-secondary);
    border-radius: 50%;
    box-shadow:
      0 -1rem 0 -0.45rem var(--color-secondary),
      -0.7rem -0.45rem 0 -0.5rem var(--color-secondary),
      0.7rem -0.45rem 0 -0.5rem var(--color-secondary);
  }

  .hero-banner__paw--1 {
    right: 8%;
    bottom: 18%;
    transform: rotate(-18deg);
  }

  .hero-banner__paw--2 {
    right: 2%;
    bottom: 29%;
    transform: scale(0.72) rotate(12deg);
  }

  .hero-banner__paw--3 {
    right: 18%;
    bottom: 7%;
    transform: scale(0.82) rotate(18deg);
  }

  .hero-banner__shadow {
    right: 18%;
    bottom: 12%;
    width: 40%;
    height: 9%;
    background: rgba(90, 45, 34, 0.14);
    border-radius: 50%;
    filter: blur(14px);
  }

  .hero-banner__image {
    position: absolute;
    inset: auto 0 6% 0;
    z-index: 2;
    width: min(80%, 21rem) !important;
    height: auto;
    margin: 0 auto;
    filter: drop-shadow(0 24px 30px rgba(90, 45, 34, 0.18));
    animation: hero-banner-float 4.8s ease-in-out infinite;
  }

  @keyframes hero-banner-float {
    0%,
    100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(-12px);
    }
  }

  @media screen and (min-width: 750px) {
    .hero-banner__inner {
      gap: 2.5rem;
      padding-top: 2.25rem;
      padding-bottom: 3.5rem;
    }

    .hero-banner__art {
      width: min(100%, 34rem);
    }

    .hero-banner__image {
      width: min(74%, 23rem) !important;
    }
  }

  @media screen and (min-width: 990px) {
    .hero-banner__inner {
      grid-template-columns: minmax(0, 1fr) minmax(22rem, 32rem);
      gap: 3rem;
      min-height: clamp(34rem, 68vh, 46rem);
      padding-top: 2.5rem;
      padding-bottom: 2.5rem;
    }

    .hero-banner__content {
      order: 1;
      padding-block: 2rem;
    }

    .hero-banner__media {
      order: 2;
      display: flex;
      align-items: center;
      justify-content: flex-end;
    }

    .hero-banner__art {
      width: min(100%, 33rem);
      margin-right: 0;
    }

    .hero-banner__heading {
      font-size: clamp(3.75rem, 5vw, 5.4rem);
    }

    .hero-banner__image {
      width: min(74%, 24rem) !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Premios canijos para perros con gran antojo."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Snacks deshidratados hechos en Mexico para consentir a tu perro con ingredientes simples, textura crujiente y mucho sabor."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "¡Compra ahora!"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FCECC9"
    }
  ],
  "presets": [
    {
      "name": "Hero banner",
      "category": "Image"
    }
  ]
}
{% endschema %}
