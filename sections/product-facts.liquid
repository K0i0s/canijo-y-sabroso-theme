                  </svg>
              {% endcase %}
            </div>
            <div class="product-facts__icon-ring" aria-hidden="true"></div>
          </div>

          <h3 class="product-facts__title">{{ block.settings.title }}</h3>
          <p class="product-facts__description">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  @keyframes pf-bob {
    0%, 100% { transform: scale(1); }
    50%       { transform: scale(1.12); }
  }

  @keyframes pf-ring-pulse {
    0%   { transform: scale(1);    opacity: 0.6; }
    100% { transform: scale(1.55); opacity: 0;   }
  }

  @keyframes pf-squiggle {
    0%, 100% { stroke-dashoffset: 0;  }
    50%       { stroke-dashoffset: 12; }
  }

  /* ── Section ─────────────────────────────────────────── */
  .product-facts {
    background: var(--pf-bg, var(--color-light-cream));
    position: relative;
    overflow: hidden;
  }

 

  /* ── Inner ───────────────────────────────────────────── */
  .product-facts__inner {
    position: relative;
    width: min(var(--page-width), calc(100% - (var(--page-margin) * 2)));
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) 0;
  }

  /* ── Heading ─────────────────────────────────────────── */
  .product-facts__heading {
    margin: 0 0 clamp(2rem, 4vw, 3rem);
    text-align: center;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: clamp(1.75rem, 4.5vw, 2.75rem);
    color: var(--color-accent);
    letter-spacing: -0.01em;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }

  .product-facts__heading-squiggle {
    display: block;
    width: clamp(120px, 30%, 200px);
    height: 12px;
    color: var(--color-secondary);
  }

  .product-facts__heading-squiggle svg {
    width: 100%;
    height: 100%;
    stroke-dasharray: 8 4;
    animation: pf-squiggle 2.8s ease-in-out infinite;
  }

  /* ── Grid ────────────────────────────────────────────── */
  .product-facts__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem;
  }

  @media screen and (min-width: 750px) {
    .product-facts__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  /* ── Cards ───────────────────────────────────────────── */
  .product-facts__card {
    --card-tilt: 0deg;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: #fff;
    border: 2.5px solid #1a1a1a;
    border-radius: 1.75rem;
    padding: clamp(1.75rem, 3.5vw, 2.25rem) clamp(1.25rem, 2.5vw, 1.75rem);
    box-shadow: 5px 6px 0px 0px #1a1a1a;
    transition: transform 0.22s cubic-bezier(.34,1.56,.64,1),
                box-shadow 0.22s cubic-bezier(.34,1.56,.64,1);
    position: relative;
    will-change: transform;
  }

  /* Teal top strip */

  @media screen and (min-width: 750px) {
    .product-facts__card:nth-child(1) { transform: rotate(-1.5deg); }
    .product-facts__card:nth-child(2) { transform: rotate(0.5deg);  }
    .product-facts__card:nth-child(3) { transform: rotate(1.5deg);  }
  }

  .product-facts__card:hover {
    transform: translateY(-8px) rotate(0deg) scale(1.02) !important;
    box-shadow: 8px 10px 0px 0px #1a1a1a;
  }

  /* ── Icon ────────────────────────────────────────────── */
  .product-facts__icon-wrap {
    position: relative;
    width: 5rem;
    height: 5rem;
    margin-bottom: 1.25rem;
    flex-shrink: 0;
  }

  .product-facts__icon {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: var(--color-secondary);
    color: #fff;
    border: 2.5px solid #1a1a1a;
    box-shadow: 3px 3px 0px 0px #1a1a1a;
    transition: transform 0.3s cubic-bezier(.34,1.56,.64,1);
  }

  .product-facts__card:hover .product-facts__icon {
    animation: pf-bob 0.6s ease-in-out;
  }

  .product-facts__icon-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 2px solid var(--color-secondary);
    opacity: 0;
    pointer-events: none;
  }

  .product-facts__card:hover .product-facts__icon-ring {
    animation: pf-ring-pulse 0.7s ease-out forwards;
  }

  /* ── Title ───────────────────────────────────────────── */
  .product-facts__title {
    margin: 0 0 0.5rem;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: var(--color-foreground);
  }

  /* ── Description ─────────────────────────────────────── */
  .product-facts__description {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgba(51, 51, 51, 0.72);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product facts",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "¿Por qué elegirnos?"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FFF6E5"
    }
  ],
  "blocks": [
    {
      "type": "fact",
      "name": "Fact",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "leaf",        "label": "Leaf"        },
            { "value": "shield",      "label": "Shield"      },
            { "value": "stethoscope", "label": "Stethoscope" },
            { "value": "wheat-off",   "label": "Wheat off"   }
          ],
          "default": "leaf"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "100% natural"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Ingredientes simples y naturales."
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Product facts",
      "blocks": [
        {
          "type": "fact",
          "settings": {
            "icon": "leaf",
            "title": "100% Natural",
            "description": "Ingredientes simples y naturales para tu mejor amigo."
          }
        },
        {
          "type": "fact",
          "settings": {
            "icon": "shield",
            "title": "Sin Conservadores",
            "description": "Sin aditivos ni químicos raros, solo lo bueno."
          }
        },
        {
          "type": "fact",
          "settings": {
            "icon": "stethoscope",
            "title": "Aprobado por Vets",
            "description": "Nutricionalmente balanceado y avalado por veterinarios."
          }
        }
      ]
    }
  ]
}
{% endschema %}