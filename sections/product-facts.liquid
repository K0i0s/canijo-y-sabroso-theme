<section class="product-facts full-width" style="--pf-bg: {{ section.settings.bg_color }};">

  <div class="product-facts__inner">
    {% if section.settings.heading != blank %}
      <h2 class="product-facts__heading">
        {{ section.settings.heading }}
        <span class="product-facts__heading-squiggle" aria-hidden="true">
          <svg viewBox="0 0 200 12" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
            <path d="M0 6 C20 0, 40 12, 60 6 S100 0, 120 6 S160 12, 180 6 S195 2, 200 6" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          </svg>
        </span>
      </h2>
    {% endif %}

    <div class="product-facts__grid">
      {% for block in section.blocks %}
        <div class="product-facts__card" {{ block.shopify_attributes }}>
          <div class="product-facts__icon-wrap">
            <div class="product-facts__icon">
