{% comment %}
  Renders a single article preview card.
  Usage: {% render 'article-card', article: article %}
  Accepts:
    - article {Object} Shopify article object
{% endcomment %}

<article class="acard">
  <a class="acard__link" href="{{ article.url }}" aria-label="{{ article.title | escape }}">
    <div class="acard__image-wrap">
      {%- if article.image -%}
        <img
          class="acard__image"
          src="{{ article.image | image_url: width: 800 }}"
          alt="{{ article.image.alt | escape | default: article.title | escape }}"
          width="800"
          height="{{ 800 | divided_by: article.image.aspect_ratio | round }}"
          loading="lazy"
        >
      {%- else -%}
        <div class="acard__image-placeholder" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            width="40"
            height="40"
          >
            <rect x="3" y="3" width="18" height="18" rx="3"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <path d="M21 15l-5-5L5 21"/>
          </svg>
        </div>
      {%- endif -%}
      <div class="acard__image-shine" aria-hidden="true"></div>
    </div>

    <div class="acard__body">
      <time class="acard__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
        {{ article.published_at | date: '%B %d, %Y' }}
      </time>
      <h2 class="acard__title">{{ article.title }}</h2>
      {%- if article.excerpt != blank -%}
        <p class="acard__excerpt">{{ article.excerpt | strip_html | truncate: 120 }}</p>
      {%- endif -%}
      <span class="acard__cta" aria-hidden="true">Leer más →</span>
    </div>
  </a>
</article>

{% stylesheet %}
  /* ── Card shell ───────────────────────────────────────── */
  .acard {
    position: relative;
    border-radius: 1.5rem;
    background: #fff;
    border: 2.5px solid #1a1a1a;
    box-shadow: 5px 6px 0px 0px #1a1a1a;
    overflow: hidden;
    transition: transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
    will-change: transform;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .acard:hover {
    transform: translateY(-6px) scale(1.012);
    box-shadow: 8px 10px 0px 0px #1a1a1a;
  }

  .acard__link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  /* ── Image ────────────────────────────────────────────── */
  .acard__image-wrap {
    position: relative;
    width: 100%;
    padding-bottom: 60%;
    overflow: hidden;
    background: var(--color-cream, #fcecc9);
    border-bottom: 2.5px solid #1a1a1a;
    flex-shrink: 0;
  }

  .acard__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    display: block;
  }

  .acard:hover .acard__image {
    transform: scale(1.05);
  }

  .acard__image-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(51, 51, 51, 0.3);
  }

  .acard__image-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.18) 0%, transparent 55%);
    pointer-events: none;
  }

  /* ── Body ─────────────────────────────────────────────── */
  .acard__body {
    padding: 1.1rem 1.2rem 1.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    flex: 1;
  }

  .acard__date {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent, #f86d4e);
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
  }

  .acard__title {
    margin: 0;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-foreground, #333);
    line-height: 1.25;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .acard__excerpt {
    margin: 0;
    font-size: 0.88rem;
    color: rgba(51, 51, 51, 0.65);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .acard__cta {
    margin-top: auto;
    padding-top: 0.5rem;
    font-size: 0.82rem;
    font-weight: 700;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    color: var(--color-accent, #f86d4e);
    transition: letter-spacing 0.2s ease;
  }

  .acard:hover .acard__cta {
    letter-spacing: 0.04em;
  }
{% endstylesheet %}
