{% comment %}
  Renders a single product card.
  Usage: {% render 'product-card', product: product %}
  Accepts:
    - product {Object} Shopify product object
{% endcomment %}

{%- liquid
  assign product_url   = product.url
  assign product_title = product.title
  assign product_price = product.price_min
  assign compare_price = product.compare_at_price_min
  assign on_sale       = false
  if compare_price > product_price
    assign on_sale = true
  endif
  assign rating_value  = product.metafields.reviews.rating.value | default: 0
  assign rating_count  = product.metafields.reviews.rating_count.value | default: 0
  assign product_image = product.featured_image
-%}

<article class="pcard">
  <a class="pcard__link" href="{{ product_url }}" aria-label="{{ product_title }}">

    {%- if on_sale -%}
      <div class="pcard__badge">Oferta</div>
    {%- endif -%}

    <div class="pcard__image-wrap">
      {%- if product_image -%}
        <img
          class="pcard__image"
          src="{{ product_image | image_url: width: 600 }}"
          alt="{{ product_image.alt | escape | default: product_title }}"
          width="600"
          height="{{ 600 | divided_by: product_image.aspect_ratio | round }}"
          loading="lazy"
        >
      {%- else -%}
        <div class="pcard__image-placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="3"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <path d="M21 15l-5-5L5 21"/>
          </svg>
        </div>
      {%- endif -%}

      <div class="pcard__image-shine" aria-hidden="true"></div>
    </div>

    <div class="pcard__body">
      {%- if rating_value > 0 -%}
        <div class="pcard__rating">
          {%- render 'star-rating', rating: rating_value, size: 'sm' -%}
          {%- if rating_count > 0 -%}
            <span class="pcard__rating-count">({{ rating_count }})</span>
          {%- endif -%}
        </div>
      {%- endif -%}

      <h3 class="pcard__title">{{ product_title }}</h3>

      <div class="pcard__price-row">
        <span class="pcard__price">{{ product_price | money }}</span>
        {%- if on_sale -%}
          <s class="pcard__compare-price">{{ compare_price | money }}</s>
        {%- endif -%}
      </div>

      <span class="pcard__cta" aria-hidden="true">Ver producto →</span>
    </div>
  </a>
</article>

{% stylesheet %}
  /* ── Card shell ─────────────────────────────────────── */
  .pcard {
    position: relative;
    border-radius: 1.5rem;
    background: #fff;
    border: 2.5px solid #1a1a1a;
    box-shadow: 5px 6px 0px 0px #1a1a1a;
    overflow: hidden;
    transition: transform 0.22s cubic-bezier(.34,1.56,.64,1),
                box-shadow 0.22s cubic-bezier(.34,1.56,.64,1);
    will-change: transform;
  }

  .pcard:hover {
    transform: translateY(-7px) scale(1.015);
    box-shadow: 8px 10px 0px 0px #1a1a1a;
  }

  .pcard__link {
    display: block;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  /* ── Sale badge ─────────────────────────────────────── */
  .pcard__badge {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    z-index: 2;
    background: var(--color-accent, #F86D4E);
    color: #fff;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    border: 2px solid #1a1a1a;
  }

  /* ── Image ──────────────────────────────────────────── */
  .pcard__image-wrap {
    position: relative;
    width: 100%;
    padding-bottom: 85%;
    overflow: hidden;
    background: var(--color-cream, #FCECC9);
    border-bottom: 2.5px solid #1a1a1a;
  }

  .pcard__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(.25,.46,.45,.94);
    display: block;
  }

  .pcard:hover .pcard__image {
    transform: scale(1.05);
  }

  .pcard__image-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(51,51,51,0.3);
  }

  /* Shine overlay */
  .pcard__image-shine {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.18) 0%, transparent 55%);
    pointer-events: none;
  }

  /* ── Body ───────────────────────────────────────────── */
  .pcard__body {
    padding: 1rem 1.1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  /* ── Rating ─────────────────────────────────────────── */
  .pcard__rating {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .pcard__rating-count {
    font-size: 0.78rem;
    color: rgba(51,51,51,0.55);
  }

  /* ── Title ──────────────────────────────────────────── */
  .pcard__title {
    margin: 0;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-foreground, #333);
    line-height: 1.25;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Price ──────────────────────────────────────────── */
  .pcard__price-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .pcard__price {
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-secondary, #0296B4);
  }

  .pcard__compare-price {
    font-size: 0.85rem;
    color: rgba(51,51,51,0.45);
  }

  /* ── CTA pill ───────────────────────────────────────── */
  .pcard__cta {
    display: inline-block;
    margin-top: 0.4rem;
    font-size: 0.82rem;
    font-weight: 700;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    color: var(--color-accent, #F86D4E);
    transition: letter-spacing 0.2s ease;
  }

  .pcard:hover .pcard__cta {
    letter-spacing: 0.04em;
  }
{% endstylesheet %}
