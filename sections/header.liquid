{%- if section.settings.menu != blank -%}
  {%- assign menu_links = section.settings.menu.links -%}
{%- else -%}
  {%- assign menu_links = blank -%}
{%- endif -%}

<header
  id="shopify-section-{{ section.id }}-header"
  class="header-section full-width"
  data-header-section
>
  <div class="header-section__shell">
    <div class="header-section__bar">
      {{- '<!-- Mobile: hamburger -->' -}}
      <div class="header-section__leading">
        <button
          class="header-section__menu-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="header-drawer-{{ section.id }}"
          aria-label="Abrir menú"
          data-header-toggle
        >
          <span class="header-section__toggle-bar"></span>
          <span class="header-section__toggle-bar"></span>
          <span class="header-section__toggle-bar"></span>
        </button>
      </div>

      {{- '<!-- Logo -->' -}}
      <a class="header-section__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        <img
          src="{{ 'canijo-y-sabroso-logo.webp' | asset_url }}"
          alt="{{ shop.name }}"
          width="72"
          height="72"
          loading="eager"
        >
      </a>

      {{- '<!-- Desktop nav -->' -}}
      <nav class="header-section__nav" aria-label="Navegación principal">
        {%- if menu_links != blank -%}
          {%- for link in menu_links -%}
            <a
              href="{{ link.url }}"
              class="header-section__nav-link{% if link.current %} is-active{% endif %}"
            >
              {{ link.title }}
            </a>
          {%- endfor -%}
        {%- else -%}
          <a href="{{ routes.root_url }}" class="header-section__nav-link{% if template.name == 'index' %} is-active{% endif %}">Home</a>
          <a href="{{ routes.collections_url }}" class="header-section__nav-link{% if template.name == 'collection' %} is-active{% endif %}">Shop</a>
          <a href="/pages/contact" class="header-section__nav-link">Contact</a>
        {%- endif -%}
      </nav>

      {{- '<!-- Action icons -->' -}}
      <div class="header-section__actions">
        <a
          class="header-section__icon-link header-section__icon-link--search"
          href="{{ routes.search_url }}"
          aria-label="Buscar"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
            <circle cx="11" cy="11" r="6.5"/>
            <path d="M16 16L21 21"/>
          </svg>
        </a>

        {%- if shop.customer_accounts_enabled -%}
          <shopify-account
            class="header-section__icon-link"
            menu="{{ section.settings.customer_account_menu }}"
          >
            {{ 'icon-account.svg' | inline_asset_content }}
          </shopify-account>
        {%- endif -%}

        <a
          class="header-section__icon-link header-section__cart-link"
          href="{{ routes.cart_url }}"
          aria-label="Carrito{% if cart.item_count > 0 %} ({{ cart.item_count }}){% endif %}"
        >
          {%- if cart.item_count > 0 -%}
            <span class="header-section__cart-count" aria-hidden="true">{{ cart.item_count }}</span>
          {%- endif -%}
          {{ 'icon-cart.svg' | inline_asset_content }}
        </a>
      </div>

    </div>
  </div>

  {{- '<!-- Mobile drawer -->' -}}
  <div class="header-section__drawer" data-header-drawer>
    <button
      class="header-section__drawer-overlay"
      type="button"
      aria-label="Cerrar menú"
      data-header-close
    ></button>

    <div
      id="header-drawer-{{ section.id }}"
      class="header-section__drawer-panel"
      role="dialog"
      aria-modal="true"
      aria-hidden="true"
      tabindex="-1"
    >
      {{- '<!-- Drawer header -->' -}}
      <div class="header-section__drawer-header">
        <span class="header-section__drawer-title">Menú</span>
        <button
          class="header-section__drawer-close"
          type="button"
          aria-label="Cerrar menú"
          data-header-close
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
            <path d="M18 6 6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>

      {{- '<!-- Drawer nav links -->' -}}
      <nav class="header-section__drawer-nav" aria-label="Menú móvil">
        {%- if menu_links != blank -%}
          {%- for link in menu_links -%}
            <a
              href="{{ link.url }}"
              class="header-section__drawer-link{% if link.current %} is-active{% endif %}"
            >
              <span>{{ link.title }}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </a>
          {%- endfor -%}
        {%- else -%}
          <a href="{{ routes.root_url }}" class="header-section__drawer-link{% if template.name == 'index' %} is-active{% endif %}">
            <span>Home</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
              <path d="m9 18 6-6-6-6"/>
            </svg>
          </a>
          <a href="{{ routes.collections_url }}" class="header-section__drawer-link{% if template.name == 'collection' %} is-active{% endif %}">
            <span>Shop</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
              <path d="m9 18 6-6-6-6"/>
            </svg>
          </a>
          <a href="/pages/contact" class="header-section__drawer-link">
            <span>Contact</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
              <path d="m9 18 6-6-6-6"/>
            </svg>
          </a>
        {%- endif -%}
      </nav>

      {{- '<!-- Drawer utility links -->' -}}
      <div class="header-section__drawer-meta">
        <a class="header-section__drawer-utility" href="{{ routes.search_url }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="6.5"/><path d="M16 16L21 21"/></svg>
          Buscar
        </a>

        {%- if shop.customer_accounts_enabled -%}
          <a class="header-section__drawer-utility" href="{{ routes.account_url }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            Mi cuenta
          </a>
        {%- endif -%}

        <a class="header-section__drawer-utility" href="{{ routes.cart_url }}">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          Carrito{%- if cart.item_count > 0 -%}&nbsp;<span class="header-section__drawer-cart-count">{{ cart.item_count }}</span>{%- endif -%}
        </a>
      </div>

    </div>
  </div>
</header>

<script>
  (() => {
    const header = document.getElementById('shopify-section-{{ section.id }}-header');
    if (!header) return;

    const root            = document.documentElement;
    const toggle          = header.querySelector('[data-header-toggle]');
    const drawerPanel     = header.querySelector('.header-section__drawer-panel');
    const closeButtons    = header.querySelectorAll('[data-header-close]');
    const primaryClose    = header.querySelector('.header-section__drawer-close');

    const setOpen = (isOpen) => {
      header.classList.toggle('is-open', isOpen);
      toggle?.setAttribute('aria-expanded', String(isOpen));
      toggle?.setAttribute('aria-label', isOpen ? 'Cerrar menú' : 'Abrir menú');
      drawerPanel?.setAttribute('aria-hidden', String(!isOpen));
      root.classList.toggle('header-drawer-open', isOpen);
      if (isOpen) primaryClose?.focus();
    };

    toggle?.addEventListener('click', () => setOpen(!header.classList.contains('is-open')));
    closeButtons.forEach(btn => btn.addEventListener('click', () => setOpen(false)));
    header.querySelectorAll('.header-section__drawer-link, .header-section__drawer-utility')
          .forEach(link => link.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && header.classList.contains('is-open')) setOpen(false);
    });

    const syncScrolled = () => header.classList.toggle('is-scrolled', window.scrollY > 8);
    syncScrolled();
    window.addEventListener('scroll', syncScrolled, { passive: true });
    window.addEventListener('resize', () => { if (window.innerWidth >= 990) setOpen(false); });
  })();
</script>

{% stylesheet %}
  /* ── Global lock ─────────────────────────────────────── */
  html.header-drawer-open,
  html.header-drawer-open body { overflow: hidden; }

  /* ── Keyframes ──────────────────────────────────────── */
  @keyframes hdr-logo-bounce {
    0%, 100% { transform: translateY(0)   rotate(0deg);  }
    30%       { transform: translateY(-5px) rotate(-3deg); }
    60%       { transform: translateY(-2px) rotate(2deg);  }
  }

  @keyframes hdr-cart-pop {
    0%   { transform: scale(0) rotate(-20deg); }
    70%  { transform: scale(1.3) rotate(5deg); }
    100% { transform: scale(1)   rotate(0deg); }
  }

  @keyframes hdr-drawer-in {
    from { transform: translateX(-100%); opacity: 0.6; }
    to   { transform: translateX(0);     opacity: 1;   }
  }

  /* ── Section base ───────────────────────────────────── */
  .header-section {
    position: sticky;
    top: 0;
    z-index: 30;
    background: var(--color-light-cream, #FFF6E5);
    border-bottom: 2.5px solid #1a1a1a;
    transition: box-shadow 0.25s ease;
  }

  .header-section.is-scrolled {
    box-shadow: 0 4px 0px 0px #1a1a1a;
  }

  /* ── Shell + bar ─────────────────────────────────────── */
  .header-section__shell {
    position: relative;
    width: min(var(--page-width), calc(100% - (var(--page-margin) * 2)));
    margin: 0 auto;
  }

  .header-section__bar {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 0.75rem;
    min-height: 4.75rem;
    padding: 0.65rem 0;
  }

  /* ── Leading (hamburger area) ───────────────────────── */
  .header-section__leading {
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  /* ── Hamburger toggle ───────────────────────────────── */
  .header-section__menu-toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.26rem;
    width: 2.7rem;
    height: 2.7rem;
    padding: 0.55rem;
    background: #fff;
    border: 2.5px solid #1a1a1a;
    border-radius: 50%;
    box-shadow: 3px 3px 0px 0px #1a1a1a;
    color: var(--color-foreground, #333);
    font: inherit;
    transition: transform 0.2s cubic-bezier(.34,1.56,.64,1),
                box-shadow 0.2s cubic-bezier(.34,1.56,.64,1),
                background 0.15s ease;
  }

  .header-section__menu-toggle:hover {
    background: var(--color-accent, #F86D4E);
    color: #fff;
    transform: scale(1.08);
    box-shadow: 4px 4px 0px 0px #1a1a1a;
  }

  .header-section__toggle-bar {
    display: block;
    width: 16px;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    transition: transform 0.22s ease, opacity 0.22s ease, width 0.22s ease;
    transform-origin: center;
  }

  /* X state */
  .header-section.is-open .header-section__toggle-bar:nth-child(1) {
    transform: translateY(4.5px) rotate(45deg);
  }
  .header-section.is-open .header-section__toggle-bar:nth-child(2) {
    opacity: 0;
    width: 0;
  }
  .header-section.is-open .header-section__toggle-bar:nth-child(3) {
    transform: translateY(-4.5px) rotate(-45deg);
  }

  /* ── Logo ───────────────────────────────────────────── */
  .header-section__logo {
    display: inline-flex;
    align-items: center;
    justify-self: center;
    flex: 0 0 auto;
    line-height: 0;
    width: clamp(4rem, 16vw, 5.25rem);
    padding: 0.2rem;
    border-radius: 50%;
    transition: transform 0.3s cubic-bezier(.34,1.56,.64,1);
  }

  .header-section__logo:hover {
    animation: hdr-logo-bounce 0.55s cubic-bezier(.34,1.56,.64,1) both;
  }

  .header-section__logo img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 50%;
    border: 2.5px solid #1a1a1a;
    box-shadow: 3px 3px 0px 0px #1a1a1a;
  }

  /* ── Desktop nav ────────────────────────────────────── */
  .header-section__nav { display: none; }

  /* ── Actions row ────────────────────────────────────── */
  .header-section__actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.3rem;
  }

  /* Icon buttons */
  .header-section__icon-link,
  .header-section shopify-account.header-section__icon-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: #fff;
    border: 2px solid #1a1a1a;
    box-shadow: 2px 2px 0px 0px #1a1a1a;
    color: var(--color-foreground, #333);
    line-height: 0;
    text-decoration: none;
    transition: transform 0.2s cubic-bezier(.34,1.56,.64,1),
                box-shadow 0.2s cubic-bezier(.34,1.56,.64,1),
                background 0.15s ease,
                color 0.15s ease;
  }

  .header-section__icon-link:hover,
  .header-section shopify-account.header-section__icon-link:hover {
    background: var(--color-secondary, #0296B4);
    color: #fff;
    border-color: #1a1a1a;
    transform: translateY(-3px) scale(1.08);
    box-shadow: 3px 4px 0px 0px #1a1a1a;
  }

  .header-section__icon-link svg,
  .header-section shopify-account.header-section__icon-link svg {
    width: 1.3rem !important;
    height: 1.3rem !important;
  }

  .header-section__icon-link--search { display: none; }

  /* Cart count badge */
  .header-section__cart-count {
    position: absolute;
    top: -0.2rem;
    right: -0.2rem;
    min-width: 1.15rem;
    height: 1.15rem;
    padding: 0 0.22rem;
    border-radius: 999px;
    background: var(--color-accent, #F86D4E);
    color: #fff;
    border: 1.5px solid #1a1a1a;
    font-size: 0.62rem;
    font-weight: 700;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    line-height: 1.05rem;
    text-align: center;
    animation: hdr-cart-pop 0.35s cubic-bezier(.34,1.56,.64,1) both;
  }

  /* ── Drawer backdrop ────────────────────────────────── */
  .header-section__drawer {
    position: fixed;
    inset: 0;
    z-index: 29;
    pointer-events: none;
  }

  .header-section__drawer-overlay {
    position: absolute;
    inset: 0;
    border: 0;
    padding: 0;
    background: rgba(26,26,26,0.45);
    backdrop-filter: blur(3px);
    opacity: 0;
    cursor: pointer;
    transition: opacity 0.25s ease;
    box-shadow: none;
    transform: none;
  }

  .header-section.is-open .header-section__drawer        { pointer-events: auto; }
  .header-section.is-open .header-section__drawer-overlay { opacity: 1; }
  .header-section.is-open .header-section__drawer-panel  {
    transform: translateX(0);
    animation: hdr-drawer-in 0.28s cubic-bezier(.34,1.56,.64,1) both;
  }

  /* ── Drawer panel ───────────────────────────────────── */
  .header-section__drawer-panel {
    position: absolute;
    top: 0;
    left: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    width: min(20rem, calc(100vw - 3rem));
    height: 100dvh;
    padding: 1.25rem;
    background: var(--color-light-cream, #FFF6E5);
    border-right: 2.5px solid #1a1a1a;
    box-shadow: 6px 0 0px 0px #1a1a1a;
    transform: translateX(-100%);
    transition: transform 0.28s cubic-bezier(.34,1.56,.64,1);
    overflow-y: auto;
    overflow-x: hidden;
  }

  /* ── Drawer header ──────────────────────────────────── */
  .header-section__drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1rem;
    border-bottom: 2px dashed rgba(2,150,180,0.3);
  }

  .header-section__drawer-title {
    margin: 0;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-accent, #F86D4E);
    letter-spacing: 0.01em;
  }

  .header-section__drawer-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: #fff;
    border: 2px solid #1a1a1a;
    box-shadow: 2px 2px 0px 0px #1a1a1a;
    color: var(--color-foreground, #333);
    font: inherit;
    transition: background 0.18s ease, color 0.18s ease,
                transform 0.2s cubic-bezier(.34,1.56,.64,1);
  }

  .header-section__drawer-close:hover {
    background: var(--color-accent, #F86D4E);
    color: #fff;
    transform: scale(1.1) rotate(90deg);
  }

  /* ── Drawer nav links ───────────────────────────────── */
  .header-section__drawer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .header-section__drawer-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1rem;
    background: #fff;
    border: 2px solid #1a1a1a;
    border-radius: 1rem;
    box-shadow: 3px 3px 0px 0px #1a1a1a;
    color: var(--color-foreground, #333);
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.2s cubic-bezier(.34,1.56,.64,1),
                box-shadow 0.2s cubic-bezier(.34,1.56,.64,1),
                background 0.15s ease,
                color 0.15s ease;
  }

  .header-section__drawer-link:hover,
  .header-section__drawer-link.is-active {
    background: var(--color-secondary, #0296B4);
    color: #fff;
    transform: translateX(4px);
    box-shadow: 4px 4px 0px 0px #1a1a1a;
  }

  /* Arrow icon inside link */
  .header-section__drawer-link svg {
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.2s ease, transform 0.2s cubic-bezier(.34,1.56,.64,1);
    flex-shrink: 0;
  }

  .header-section__drawer-link:hover svg,
  .header-section__drawer-link.is-active svg {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Drawer utility links ───────────────────────────── */
  .header-section__drawer-meta {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-top: 0.5rem;
    border-top: 2px dashed rgba(51,51,51,0.12);
    margin-top: auto;
  }

  .header-section__drawer-utility {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 0.85rem;
    border-radius: 999px;
    color: rgba(51,51,51,0.65);
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.18s ease, color 0.18s ease;
  }

  .header-section__drawer-utility:hover {
    background: var(--color-cream, #FCECC9);
    color: var(--color-foreground, #333);
  }

  .header-section__drawer-cart-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.2rem;
    height: 1.2rem;
    padding: 0 0.25rem;
    border-radius: 999px;
    background: var(--color-accent, #F86D4E);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    border: 1.5px solid #1a1a1a;
  }

  /* ────────────────────────────────────────────────────── */
  /* DESKTOP (990px+)                                       */
  /* ────────────────────────────────────────────────────── */
  @media screen and (min-width: 990px) {
    .header-section__bar {
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 1.5rem;
      min-height: 5.25rem;
    }

    /* Hide mobile toggle + drawer */
    .header-section__leading,
    .header-section__drawer { display: none; }

    /* Logo left-aligned on desktop */
    .header-section__logo {
      justify-self: flex-start;
      width: clamp(3.75rem, 7vw, 5rem);
    }

    /* Show desktop nav */
    .header-section__nav {
      display: flex;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    .header-section__nav-link {
      display: inline-flex;
      align-items: center;
      padding: 0.55rem 1.1rem;
      border-radius: 999px;
      background: transparent;
      border: 2px solid transparent;
      color: var(--color-foreground, #333);
      font-family: var(--font-heading-family), 'Fredoka', sans-serif;
      font-size: 0.95rem;
      font-weight: 700;
      letter-spacing: 0.01em;
      text-decoration: none;
      transition: background 0.18s ease,
                  color 0.18s ease,
                  border-color 0.18s ease,
                  transform 0.2s cubic-bezier(.34,1.56,.64,1),
                  box-shadow 0.2s cubic-bezier(.34,1.56,.64,1);
    }

    .header-section__nav-link:hover {
      background: #fff;
      color: var(--color-secondary, #0296B4);
      border-color: #1a1a1a;
      box-shadow: 3px 3px 0px 0px #1a1a1a;
      transform: translateY(-2px);
    }

    .header-section__nav-link.is-active {
      background: var(--color-accent, #F86D4E);
      color: #fff;
      border-color: #1a1a1a;
      box-shadow: 3px 3px 0px 0px #1a1a1a;
    }

    /* Show search on desktop */
    .header-section__icon-link--search { display: inline-flex; }
  }
{% endstylesheet %}

