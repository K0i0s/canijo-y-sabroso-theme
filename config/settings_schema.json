[
  {
    "name": "theme_info",
    "theme_name": "Canijo y Sabroso",
    "theme_version": "0.1.0",
    "theme_author": "Shopify",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "fredoka_n4",
        "label": "t:general.heading_font"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "nunito_sans_n4",
        "label": "t:general.body_font"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_accent",
        "default": "#F86D4E",
        "label": "t:labels.accent"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "default": "#0296B4",
        "label": "t:labels.secondary"
      },
      {
        "type": "color",
        "id": "color_cream",
        "default": "#FCECC9",
        "label": "t:labels.cream"
      },
      {
        "type": "color",
        "id": "color_light_cream",
        "default": "#FFF6E5",
        "label": "t:labels.light_cream"
      },
      {
        "type": "color",
        "id": "color_background",
        "default": "#FFF6E5",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "color_foreground",
        "default": "#333333",
        "label": "t:labels.foreground"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
