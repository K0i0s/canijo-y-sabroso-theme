<section class="social-media full-width">
  <div class="social-media__inner">
    {%- if section.settings.heading != blank -%}
      <p class="social-media__label">{{ section.settings.heading }}</p>
    {%- endif -%}

    <div class="social-media__icons">

      {%- if section.settings.instagram_url != blank -%}
        <a
          class="social-media__btn social-media__btn--instagram"
          href="{{ section.settings.instagram_url }}"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Síguenos en Instagram"
        >
          <span class="social-media__btn-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
            </svg>
          </span>
          <span class="social-media__btn-label">Instagram</span>
        </a>
      {%- endif -%}

      {%- if section.settings.tiktok_url != blank -%}
        <a
          class="social-media__btn social-media__btn--tiktok"
          href="{{ section.settings.tiktok_url }}"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Síguenos en TikTok"
        >
          <span class="social-media__btn-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.32 6.32 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.76a4.85 4.85 0 0 1-1.01-.07z"/>
            </svg>
          </span>
          <span class="social-media__btn-label">TikTok</span>
        </a>
      {%- endif -%}

      {%- if section.settings.facebook_url != blank -%}
        <a
          class="social-media__btn social-media__btn--facebook"
          href="{{ section.settings.facebook_url }}"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Síguenos en Facebook"
        >
          <span class="social-media__btn-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </span>
          <span class="social-media__btn-label">Facebook</span>
        </a>
      {%- endif -%}

    </div>
  </div>
</section>

{% stylesheet %}
  /* ── Keyframes ──────────────────────────────────────── */
  @keyframes sm-spin {
    from { transform: rotate(0deg);   }
    to   { transform: rotate(360deg); }
  }

  @keyframes sm-wiggle {
    0%, 100% { transform: rotate(0deg);   }
    25%       { transform: rotate(-12deg); }
    75%       { transform: rotate(12deg);  }
  }

  @keyframes sm-star-pulse {
    0%, 100% { transform: scale(1)   rotate(var(--star-rot, 0deg)); opacity: 0.45; }
    50%       { transform: scale(1.4) rotate(var(--star-rot, 0deg)); opacity: 0.8;  }
  }

  /* ── Section ────────────────────────────────────────── */
  .social-media {
    position: relative;
    background: var(--color-cream, #FCECC9);
    overflow: hidden;
  }


  /* ── Inner ──────────────────────────────────────────── */
  .social-media__inner {
    position: relative;
    width: min(var(--page-width), calc(100% - (var(--page-margin) * 2)));
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 3.5rem) 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  /* ── Label ──────────────────────────────────────────── */
  .social-media__label {
    margin: 0;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: clamp(1.1rem, 2.5vw, 1.35rem);
    font-weight: 700;
    color: var(--color-foreground, #333);
    letter-spacing: 0.01em;
  }

  /* ── Icons row ──────────────────────────────────────── */
  .social-media__icons {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  /* ── Buttons ────────────────────────────────────────── */
  .social-media__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.65rem 1.4rem 0.65rem 1rem;
    text-decoration: none;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    border: 2.5px solid #1a1a1a;
    border-radius: 999px;
    box-shadow: 4px 4px 0px 0px #1a1a1a;
    color: #fff;
    transition: transform 0.2s cubic-bezier(.34,1.56,.64,1),
                box-shadow 0.2s cubic-bezier(.34,1.56,.64,1);
    will-change: transform;
  }

  .social-media__btn:hover {
    transform: translateY(-5px) scale(1.05);
    box-shadow: 6px 7px 0px 0px #1a1a1a;
  }

  .social-media__btn:active {
    transform: translateY(1px);
    box-shadow: 2px 2px 0px 0px #1a1a1a;
  }

  /* Per-platform colours */
  .social-media__btn--instagram {
    background: linear-gradient(135deg, #f9ce34, #ee2a7b, #6228d7);
  }

  .social-media__btn--tiktok {
    background: #111;
  }

  .social-media__btn--facebook {
    background: #1877f2;
  }

  /* Icon container */
  .social-media__btn-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(255,255,255,0.18);
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .social-media__btn:hover .social-media__btn-icon {
    animation: sm-wiggle 0.5s ease-in-out;
  }

  /* TikTok icon gets a spin instead */
  .social-media__btn--tiktok:hover .social-media__btn-icon {
    animation: sm-spin 0.6s cubic-bezier(.34,1.56,.64,1);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Social media",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Label text",
      "default": "¡Síguenos en redes!"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    }
  ],
  "presets": [
    {
      "name": "Social media"
    }
  ]
}
{% endschema %}