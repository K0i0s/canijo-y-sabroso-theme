<section class="featured-products full-width">

  {{- '<!-- Decorative elements -->' -}}
  <div class="featured-products__deco featured-products__deco--bone" aria-hidden="true">
    <svg width="52" height="26" viewBox="0 0 52 26" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="7"  cy="7"  r="6" fill="currentColor" opacity="0.16"/>
      <circle cx="7"  cy="19" r="6" fill="currentColor" opacity="0.16"/>
      <circle cx="45" cy="7"  r="6" fill="currentColor" opacity="0.16"/>
      <circle cx="45" cy="19" r="6" fill="currentColor" opacity="0.16"/>
      <rect x="10" y="10" width="32" height="6" rx="3" fill="currentColor" opacity="0.16"/>
    </svg>
  </div>

  <div class="featured-products__inner">

    {{- '<!-- Header -->' -}}
    <div class="featured-products__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="featured-products__heading">
          {{ section.settings.heading }}
          <span class="featured-products__heading-squiggle" aria-hidden="true">
            <svg viewBox="0 0 220 14" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
              <path d="M0 7 C22 1, 44 13, 66 7 S110 1, 132 7 S176 13, 198 7 S215 3, 220 7" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/>
            </svg>
          </span>
        </h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="featured-products__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {{- '<!-- Grid -->' -}}
    {%- assign collection = collections[section.settings.collection] -%}
    {%- assign product_limit = section.settings.products_to_show | default: 4 -%}

    {%- if collection != blank -%}
      <div class="featured-products__grid">
        {%- for product in collection.products limit: product_limit -%}
          {%- render 'product-card', product: product -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      {{- '<!-- Placeholder cards when no collection is set -->' -}}
      <div class="featured-products__grid">
        {%- for i in (1..6) -%}
          <div class="featured-products__placeholder-card">
            <div class="featured-products__placeholder-image"></div>
            <div class="featured-products__placeholder-body">
              <div class="featured-products__placeholder-line featured-products__placeholder-line--short"></div>
              <div class="featured-products__placeholder-line"></div>
              <div class="featured-products__placeholder-line featured-products__placeholder-line--med"></div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {{- '<!-- CTA -->' -}}
    {%- assign cta_url = collection.url | default: '/collections/all' -%}
    {%- if section.settings.show_cta -%}
      <div class="featured-products__cta-wrap">
        <a class="featured-products__cta" href="{{ cta_url }}">
          <span>{{ section.settings.cta_label | default: 'Ver todo el catálogo' }}</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
  /* ── Keyframes ──────────────────────────────────────── */
  @keyframes fp-squiggle {
    0%, 100% { stroke-dashoffset: 0;  }
    50%       { stroke-dashoffset: 14; }
  }

  @keyframes fp-cta-bounce {
    0%, 100% { transform: translateX(0);  }
    50%       { transform: translateX(4px); }
  }

  @keyframes fp-shimmer {
    0%   { background-position: -400px 0; }
    100% { background-position:  400px 0; }
  }

  /* ── Section ────────────────────────────────────────── */
  .featured-products {
    position: relative;
    background: var(--color-background, #FFF6E5);
    overflow: hidden;
  }

  /* Polka dot texture */
  .featured-products::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(248,109,78,0.09) 2px, transparent 2px);
    background-size: 32px 32px;
    pointer-events: none;
  }

  /* ── Decorative shapes ──────────────────────────────── */
  .featured-products__deco {
    position: absolute;
    pointer-events: none;
    user-select: none;
  }

  .featured-products__deco--bone {
    top: 1.5rem;
    right: 2.5rem;
    color: var(--color-accent, #F86D4E);
    transform: rotate(12deg);
  }


  /* ── Inner ──────────────────────────────────────────── */
  .featured-products__inner {
    position: relative;
    width: min(var(--page-width), calc(100% - (var(--page-margin) * 2)));
    margin: 0 auto;
    padding: clamp(3.5rem, 7vw, 5.5rem) 0;
  }

  /* ── Header ─────────────────────────────────────────── */
  .featured-products__header {
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .featured-products__heading {
    margin: 0 0 0.4rem;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: clamp(1.75rem, 4.5vw, 2.75rem);
    color: var(--color-accent, #F86D4E);
    letter-spacing: -0.01em;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
  }

  .featured-products__heading-squiggle {
    display: block;
    width: clamp(140px, 35%, 220px);
    height: 14px;
    color: var(--color-secondary, #0296B4);
  }

  .featured-products__heading-squiggle svg {
    width: 100%;
    height: 100%;
    stroke-dasharray: 10 4;
    animation: fp-squiggle 3s ease-in-out infinite;
  }

  .featured-products__subheading {
    margin: 0.6rem auto 0;
    max-width: 42ch;
    font-size: clamp(0.9rem, 2vw, 1.05rem);
    color: rgba(51,51,51,0.65);
    line-height: 1.55;
  }

  /* ── Grid ───────────────────────────────────────────── */
  .featured-products__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  @media screen and (min-width: 750px) {
    .featured-products__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  @media screen and (min-width: 1100px) {
    .featured-products__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.75rem;
    }
  }

  /* Staggered load-in animation for cards */
  .featured-products__grid > * {
    animation: fp-card-in 0.45s cubic-bezier(.34,1.56,.64,1) both;
  }

  @keyframes fp-card-in {
    from { opacity: 0; transform: translateY(20px) scale(0.96); }
    to   { opacity: 1; transform: translateY(0)    scale(1);    }
  }

  .featured-products__grid > *:nth-child(1) { animation-delay: 0.05s; }
  .featured-products__grid > *:nth-child(2) { animation-delay: 0.12s; }
  .featured-products__grid > *:nth-child(3) { animation-delay: 0.19s; }
  .featured-products__grid > *:nth-child(4) { animation-delay: 0.26s; }
  .featured-products__grid > *:nth-child(5) { animation-delay: 0.33s; }
  .featured-products__grid > *:nth-child(6) { animation-delay: 0.40s; }

  /* ── Placeholder skeleton cards ─────────────────────── */
  .featured-products__placeholder-card {
    border-radius: 1.5rem;
    border: 2.5px solid #1a1a1a;
    overflow: hidden;
    box-shadow: 5px 6px 0px 0px #1a1a1a;
    background: #fff;
  }

  .featured-products__placeholder-image {
    width: 100%;
    padding-bottom: 85%;
    background: var(--color-cream, #FCECC9);
    background-image: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.5) 50%, transparent 100%);
    background-size: 400px 100%;
    animation: fp-shimmer 1.6s infinite;
    border-bottom: 2.5px solid #1a1a1a;
  }

  .featured-products__placeholder-body {
    padding: 1rem 1.1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .featured-products__placeholder-line {
    height: 12px;
    border-radius: 999px;
    background: var(--color-cream, #FCECC9);
    background-image: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.6) 50%, transparent 100%);
    background-size: 400px 100%;
    animation: fp-shimmer 1.6s infinite;
    width: 100%;
  }

  .featured-products__placeholder-line--short { width: 55%; }
  .featured-products__placeholder-line--med   { width: 70%; }

  /* ── CTA button ─────────────────────────────────────── */
  .featured-products__cta-wrap {
    display: flex;
    justify-content: center;
    margin-top: clamp(2rem, 4vw, 2.75rem);
  }

  .featured-products__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 2rem;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: #fff;
    background: var(--color-accent, #F86D4E);
    border: 2.5px solid #1a1a1a;
    border-radius: 999px;
    box-shadow: 4px 5px 0px 0px #1a1a1a;
    transition: transform 0.2s cubic-bezier(.34,1.56,.64,1),
                box-shadow 0.2s cubic-bezier(.34,1.56,.64,1);
  }

  .featured-products__cta:hover {
    transform: translateY(-4px) scale(1.03);
    box-shadow: 6px 8px 0px 0px #1a1a1a;
  }

  .featured-products__cta:hover svg {
    animation: fp-cta-bounce 0.5s ease-in-out infinite;
  }

  .featured-products__cta:active {
    transform: translateY(1px);
    box-shadow: 2px 3px 0px 0px #1a1a1a;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Los favoritos de tu Canijo"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Recetas hechas con amor, aprobadas por colas movidas."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Show CTA button",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "Ver todo el catálogo"
    }
  ],
  "presets": [
    {
      "name": "Featured products"
    }
  ]
}
{% endschema %}
