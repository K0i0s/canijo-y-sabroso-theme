<section
  class="hero-banner full-width"
  style="--hero-bg: {{ section.settings.bg_color }};"
>

  <div class="hero-banner__inner">

    {{- '<!-- Media -->' -}}
    <div class="hero-banner__media">
      <div class="hero-banner__art">

        {{- '<!-- Rotating blob rings behind image -->' -}}
        <div class="hero-banner__ring hero-banner__ring--outer" aria-hidden="true"></div>
        <div class="hero-banner__ring hero-banner__ring--inner" aria-hidden="true"></div>

        {{- '<!-- Floating badges -->' -}}
        <div class="hero-banner__badge hero-banner__badge--natural" aria-hidden="true">
          <span>🌿</span> 100% Natural
        </div>

        {{- '<!-- Product image -->' -}}
        <div class="hero-banner__image-frame">
          {%- if section.settings.image != blank -%}
            {{
              section.settings.image
              | image_url: width: 900
              | image_tag:
                class: 'hero-banner__image',
                widths: '360, 520, 720, 900',
                sizes: '(min-width: 990px) 42vw, 78vw',
                loading: 'eager',
                alt: section.settings.heading
            }}
          {%- else -%}
            <img
              class="hero-banner__image"
              src="{{ 'hero-banner-canijo-y-sabroso.webp' | asset_url }}"
              alt="{{ section.settings.heading | escape }}"
              width="900"
              height="900"
              loading="eager"
            >
          {%- endif -%}
        </div>

        {{- '<!-- Ground shadow -->' -}}
        <div class="hero-banner__shadow" aria-hidden="true"></div>
      </div>
    </div>

    {{- '<!-- Content -->' -}}
    <div class="hero-banner__content">

      {{- '<!-- Eyebrow badge -->' -}}
      <div class="hero-banner__eyebrow">
        Canijo y Sabroso
      </div>

      {{- '<!-- Heading -->' -}}
      <h1 class="hero-banner__heading">
        {{ section.settings.heading }}
        <span class="hero-banner__heading-squiggle" aria-hidden="true">
          <svg viewBox="0 0 300 16" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
            <path d="M0 8 C30 1, 60 15, 90 8 S150 1, 180 8 S240 15, 270 8 S292 3, 300 8" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
          </svg>
        </span>
      </h1>

      {{- '<!-- Subtext -->' -}}
      <div class="hero-banner__subtext rte">
        <p>{{ section.settings.subtext }}</p>
      </div>

      {{- '<!-- CTA button -->' -}}
      {%- if section.settings.button_text != blank -%}
        {%- if section.settings.button_url != blank -%}
          <a class="hero-banner__cta" href="{{ section.settings.button_url }}">
            <span>{{ section.settings.button_text }}</span>
            <span class="hero-banner__cta-icon" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </span>
          </a>
        {%- else -%}
          <span class="hero-banner__cta hero-banner__cta--static">
            {{ section.settings.button_text }}
          </span>
        {%- endif -%}
      {%- endif -%}

    </div>
  </div>
</section>

{% stylesheet %}
  /* ── Keyframes ──────────────────────────────────────── */
  @keyframes hb-squiggle {
    0%, 100% { stroke-dashoffset: 0;  }
    50%       { stroke-dashoffset: 16; }
  }

  @keyframes hb-float {
    0%, 100% { transform: translateY(0px)   rotate(var(--rot, 0deg)); }
    50%       { transform: translateY(-10px) rotate(var(--rot, 0deg)); }
  }

  @keyframes hb-float-slow {
    0%, 100% { transform: translateY(0px)  rotate(var(--rot, 0deg)); }
    50%       { transform: translateY(-6px) rotate(var(--rot, 0deg)); }
  }

  @keyframes hb-star-spin {
    from { transform: rotate(0deg)   scale(var(--sc, 1)); }
    to   { transform: rotate(360deg) scale(var(--sc, 1)); }
  }

  @keyframes hb-ring-spin-cw {
    from { transform: rotate(0deg);   }
    to   { transform: rotate(360deg); }
  }

  @keyframes hb-ring-spin-ccw {
    from { transform: rotate(0deg);    }
    to   { transform: rotate(-360deg); }
  }

  @keyframes hb-badge-bob {
    0%, 100% { transform: translateY(0)   rotate(var(--badge-tilt, 0deg)); }
    50%       { transform: translateY(-6px) rotate(var(--badge-tilt, 0deg)); }
  }

  @keyframes hb-image-pop {
    from { opacity: 0; transform: translateY(16px) scale(0.94); }
    to   { opacity: 1; transform: translateY(0)    scale(1);    }
  }

  @keyframes hb-content-in {
    from { opacity: 0; transform: translateX(-20px); }
    to   { opacity: 1; transform: translateX(0);     }
  }

  @keyframes hb-arrow-slide {
    0%, 100% { transform: translateX(0);   }
    50%       { transform: translateX(5px); }
  }

  /* ── Section ────────────────────────────────────────── */
  .hero-banner {
    position: relative;
    background: var(--hero-bg, #FCECC9);
    overflow: hidden;
  }

  /* Polka dot texture */
  .hero-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(2,150,180,0.10) 2px, transparent 2px);
    background-size: 30px 30px;
    pointer-events: none;
  }

  /* Bottom wave */
  .hero-banner::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 32px;
    background: var(--color-light-cream, #FFF6E5);
    clip-path: ellipse(55% 100% at 50% 100%);
    pointer-events: none;
  }


  /* Dots cluster — pure CSS dot grid accent */
  .hero-banner__dots-cluster {
    position: absolute;
    bottom: 15%;
    right: 3%;
    width: 80px;
    height: 80px;
    background-image: radial-gradient(circle, rgba(248,109,78,0.3) 2.5px, transparent 2.5px);
    background-size: 14px 14px;
    opacity: 0.7;
  }

  /* ── Inner wrapper ──────────────────────────────────── */
  .hero-banner__inner {
    position: relative;
    z-index: 1;
    width: min(var(--page-width), calc(100% - (var(--page-margin) * 2)));
    margin: 0 auto;
    display: grid;
    gap: 2rem;
    padding: clamp(2.5rem, 5vw, 3.5rem) 0 clamp(3.5rem, 7vw, 5rem);
  }

  /* ── Media area ─────────────────────────────────────── */
  .hero-banner__media {
    order: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-banner__art {
    position: relative;
    width: min(100%, 28rem);
    aspect-ratio: 1 / 1;
  }

  /* ── Rotating dashed rings ──────────────────────────── */
  .hero-banner__ring {
    position: absolute;
    border-radius: 50%;
    border: 2.5px dashed rgba(2,150,180,0.28);
  }

  .hero-banner__ring--outer {
    inset: 2%;
    animation: hb-ring-spin-cw 20s linear infinite;
  }

  .hero-banner__ring--inner {
    inset: 12%;
    border-color: rgba(248,109,78,0.20);
    animation: hb-ring-spin-ccw 14s linear infinite;
  }

  /* ── Floating sticker badges on image ──────────────── */
  .hero-banner__badge {
    position: absolute;
    z-index: 4;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem 0.75rem;
    background: #fff;
    border: 2.5px solid #1a1a1a;
    border-radius: 999px;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    white-space: nowrap;
    box-shadow: 3px 3px 0px 0px #1a1a1a;
    animation: hb-badge-bob 4s ease-in-out infinite;
  }

  .hero-banner__badge--natural {
    --badge-tilt: -4deg;
    top: 10%;
    left: -2%;
    color: var(--color-foreground, #333);
    animation-delay: 0s;
  }

  .hero-banner__badge--rating {
    --badge-tilt: 3deg;
    bottom: 22%;
    right: -2%;
    color: var(--color-foreground, #333);
    animation-delay: 1.5s;
    gap: 0.4rem;
  }

  .hero-banner__badge-stars {
    color: var(--color-accent, #F86D4E);
    font-size: 0.65rem;
    letter-spacing: -0.03em;
  }

  /* ── Image frame ────────────────────────────────────── */
  .hero-banner__image-frame {
    position: absolute;
    inset: 15% 10%;
    z-index: 3;
    background: var(--color-secondary, #0296B4);
    border: 3px solid #1a1a1a;
    border-radius: 50%;
    box-shadow: 6px 7px 0px 0px #1a1a1a;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    animation: hb-image-pop 0.6s cubic-bezier(.34,1.56,.64,1) 0.1s both;
  }

  .hero-banner__image {
    position: relative;
    z-index: 1;
    width: 92% !important;
    height: auto;
    display: block;
    object-fit: contain;
    object-position: bottom center;
    filter: drop-shadow(0 -4px 12px rgba(0,0,0,0.12));
  }

  /* Ground shadow */
  .hero-banner__shadow {
    position: absolute;
    bottom: 10%;
    left: 50%;
    transform: translateX(-50%);
    width: 38%;
    height: 6%;
    background: rgba(90,45,34,0.12);
    border-radius: 50%;
    filter: blur(12px);
    z-index: 0;
  }

  /* ── Content ────────────────────────────────────────── */
  .hero-banner__content {
    order: 2;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-content: center;
    animation: hb-content-in 0.5s cubic-bezier(.34,1.56,.64,1) 0.15s both;
  }

  /* ── Eyebrow badge ──────────────────────────────────── */
  .hero-banner__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    width: fit-content;
    padding: 0.4rem 0.9rem;
    background: #fff;
    border: 2px solid #1a1a1a;
    border-radius: 999px;
    box-shadow: 3px 3px 0px 0px #1a1a1a;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-secondary, #0296B4);
  }

  .hero-banner__eyebrow svg { color: var(--color-secondary, #0296B4); }

  /* ── Heading ────────────────────────────────────────── */
  .hero-banner__heading {
    margin: 0;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: clamp(2.4rem, 8vw, 4.25rem);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--color-accent, #F86D4E);
    text-wrap: balance;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .hero-banner__heading-squiggle {
    display: block;
    width: clamp(180px, 60%, 300px);
    height: 16px;
    color: var(--color-secondary, #0296B4);
  }

  .hero-banner__heading-squiggle svg {
    width: 100%;
    height: 100%;
    stroke-dasharray: 12 5;
    animation: hb-squiggle 3.5s ease-in-out infinite;
  }

  /* ── Subtext ────────────────────────────────────────── */
  .hero-banner__subtext {
    max-width: 34ch;
  }

  .hero-banner__subtext p {
    margin: 0;
    font-size: clamp(0.95rem, 2.5vw, 1.1rem);
    line-height: 1.6;
    color: rgba(51,51,51,0.85);
  }

  /* ── CTA button ─────────────────────────────────────── */
  .hero-banner__cta,
  .hero-banner__cta:visited {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    width: fit-content;
    padding: 0.9rem 1.75rem;
    border-radius: 999px;
    background: var(--color-accent, #F86D4E);
    color: #fff;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    border: 2.5px solid #1a1a1a;
    box-shadow: 5px 6px 0px 0px #1a1a1a;
    margin-top: 0.35rem;
    transition: transform 0.22s cubic-bezier(.34,1.56,.64,1),
                box-shadow 0.22s cubic-bezier(.34,1.56,.64,1),
                background 0.15s ease;
  }

  .hero-banner__cta:hover {
    background: #e85a3a;
    transform: translateY(-5px) scale(1.03);
    box-shadow: 8px 9px 0px 0px #1a1a1a;
  }

  .hero-banner__cta:hover .hero-banner__cta-icon svg {
    animation: hb-arrow-slide 0.5s ease-in-out infinite;
  }

  .hero-banner__cta:active {
    transform: translateY(1px) scale(0.98);
    box-shadow: 2px 3px 0px 0px #1a1a1a;
  }

  .hero-banner__cta--static { cursor: default; }

  .hero-banner__cta-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 50%;
    background: rgba(255,255,255,0.22);
    flex-shrink: 0;
  }

  /* ── Responsive ─────────────────────────────────────── */
  @media screen and (min-width: 600px) {
    .hero-banner__art { width: min(100%, 32rem); }

    .hero-banner__badge--natural { left: 0; }
    .hero-banner__badge--rating  { right: 0; }
  }

  @media screen and (min-width: 990px) {
    .hero-banner__inner {
      grid-template-columns: minmax(0, 1fr) minmax(22rem, 30rem);
      gap: 4rem;
      min-height: clamp(34rem, 68vh, 46rem);
      padding-top: 3rem;
      padding-bottom: 4rem;
      align-items: center;
    }

    .hero-banner__content {
      order: 1;
      animation-name: hb-content-in;
    }

    .hero-banner__media {
      order: 2;
      justify-content: flex-end;
    }

    .hero-banner__art {
      width: min(100%, 33rem);
      margin-right: 0;
    }

    .hero-banner__heading {
      font-size: clamp(3.5rem, 5vw, 5rem);
    }

    .hero-banner__badge--natural { left: -4%; }
    .hero-banner__badge--rating  { right: -4%; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Premios canijos para perros con gran antojo."
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Snacks deshidratados hechos en México para consentir a tu perro con ingredientes simples, textura crujiente y mucho sabor."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "¡Compra ahora!"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FCECC9"
    }
  ],
  "presets": [
    {
      "name": "Hero banner",
      "category": "Image"
    }
  ]
}
{% endschema %}