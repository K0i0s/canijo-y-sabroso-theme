<section class="why-us full-width">
  <div class="why-us__inner">
    {{- '<!-- Header -->' -}}
    <div class="why-us__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="why-us__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="why-us__heading">
          {{ section.settings.heading }}
          <span class="why-us__heading-squiggle" aria-hidden="true">
            <svg viewBox="0 0 220 14" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
              <path d="M0 7 C22 1, 44 13, 66 7 S110 1, 132 7 S176 13, 198 7 S215 3, 220 7" stroke="currentColor" stroke-width="3.5" stroke-linecap="round"/>
            </svg>
          </span>
        </h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="why-us__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {{- '<!-- Table -->' -}}
    <div class="why-us__table-wrap">
      <table class="why-us__table" role="table">
        <thead>
          <tr class="why-us__header-row">
            {{- '<!-- Empty feature col — transparent, blends with bg -->' -}}
            <th class="why-us__th why-us__th--feature" scope="col">
              <span class="why-us__sr-only">Característica</span>
            </th>

            {{- '<!-- Canijo col — logo image -->' -}}
            <th class="why-us__th why-us__th--canijo" scope="col">
              <div class="why-us__col-header why-us__col-header--canijo">
                <a
                  class="why-us__brand-logo"
                  href="{{ routes.root_url }}"
                  aria-label="{{ section.settings.brand_name | default: 'Canijo y Sabroso' }}"
                >
                  <img
                    src="{{ 'canijo-y-sabroso-logo.webp' | asset_url }}"
                    alt="{{ section.settings.brand_name | default: 'Canijo y Sabroso' }}"
                    width="140"
                    height="140"
                    loading="lazy"
                  >
                </a>
              </div>
            </th>

            {{- '<!-- Competitor col — name only, no icon -->' -}}
            <th class="why-us__th why-us__th--competitor" scope="col">
              <div class="why-us__col-header why-us__col-header--competitor">
                <span class="why-us__col-name">
                  {{- section.settings.competitor_name | default: 'Snacks promedio' -}}
                </span>
              </div>
            </th>
          </tr>
        </thead>

        <tbody>
          {%- for block in section.blocks -%}
            <tr class="why-us__row{% cycle ' why-us__row--odd', ' why-us__row--even' %}" {{ block.shopify_attributes }}>
              {{- '<!-- Feature label — no emoji -->' -}}
              <td class="why-us__td why-us__td--feature">
                <span class="why-us__feature-label">{{ block.settings.label }}</span>
              </td>

              {{- '<!-- Canijo value -->' -}}
              <td class="why-us__td why-us__td--canijo">
                {%- if block.settings.canijo_value == 'yes' -%}
                  <span class="why-us__check why-us__check--yes" role="img" aria-label="Sí">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="17"
                      height="17"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M20 6 9 17l-5-5"/>
                    </svg>
                  </span>
                {%- elsif block.settings.canijo_value == 'no' -%}
                  <span class="why-us__check why-us__check--no" role="img" aria-label="No">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="15"
                      height="15"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M18 6 6 18M6 6l12 12"/>
                    </svg>
                  </span>
                {%- else -%}
                  <span class="why-us__check why-us__check--text">{{ block.settings.canijo_value }}</span>
                {%- endif -%}
              </td>

              {{- '<!-- Competitor value -->' -}}
              <td class="why-us__td why-us__td--competitor">
                {%- if block.settings.competitor_value == 'yes' -%}
                  <span class="why-us__check why-us__check--yes" role="img" aria-label="Sí">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="17"
                      height="17"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M20 6 9 17l-5-5"/>
                    </svg>
                  </span>
                {%- elsif block.settings.competitor_value == 'no' -%}
                  <span class="why-us__check why-us__check--no" role="img" aria-label="No">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="15"
                      height="15"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M18 6 6 18M6 6l12 12"/>
                    </svg>
                  </span>
                {%- else -%}
                  <span class="why-us__check why-us__check--text">{{ block.settings.competitor_value }}</span>
                {%- endif -%}
              </td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>

    {{- '<!-- CTA -->' -}}
    {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
      <div class="why-us__cta-wrap">
        <a class="why-us__cta" href="{{ section.settings.cta_url }}">
          {{ section.settings.cta_label }}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="17"
            height="17"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  /* ── Keyframes ──────────────────────────────────────── */
  @keyframes wu-squiggle {
    0%,
    100% {
      stroke-dashoffset: 0;
    }
    50% {
      stroke-dashoffset: 14;
    }
  }

  @keyframes wu-check-pop {
    0% {
      transform: scale(0) rotate(-15deg);
      opacity: 0;
    }
    70% {
      transform: scale(1.2) rotate(4deg);
      opacity: 1;
    }
    100% {
      transform: scale(1) rotate(0deg);
      opacity: 1;
    }
  }

  @keyframes wu-cta-arrow {
    0%,
    100% {
      transform: translateX(0);
    }
    50% {
      transform: translateX(5px);
    }
  }

  /* ── Section ────────────────────────────────────────── */
  .why-us {
    position: relative;
    background: var(--color-light-cream, #fff6e5);
    overflow: hidden;
  }

  .why-us::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(248, 109, 78, 0.08) 2px, transparent 2px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  /* ── Inner ──────────────────────────────────────────── */
  .why-us__inner {
    position: relative;
    width: min(var(--page-width, 90rem), calc(100% - (var(--page-margin, 20px) * 2)));
    margin: 0 auto;
    padding: clamp(3rem, 6vw, 5rem) 0;
  }

  /* ── Header ─────────────────────────────────────────── */
  .why-us__header {
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }

  .why-us__eyebrow {
    margin: 0 0 0.6rem;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-secondary, #0296b4);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .why-us__eyebrow::before,
  .why-us__eyebrow::after {
    content: '';
    display: inline-block;
    width: 22px;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
  }

  .why-us__heading {
    margin: 0 0 0.5rem;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: clamp(1.75rem, 4.5vw, 2.75rem);
    color: var(--color-accent, #f86d4e);
    letter-spacing: -0.01em;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    line-height: 1.15;
  }

  .why-us__heading-squiggle {
    display: block;
    width: clamp(130px, 35%, 220px);
    height: 14px;
    color: var(--color-secondary, #0296b4);
  }

  .why-us__heading-squiggle svg {
    width: 100%;
    height: 100%;
    stroke-dasharray: 10 4;
    animation: wu-squiggle 3.2s ease-in-out infinite;
  }

  .why-us__subheading {
    margin: 0.65rem auto 0;
    max-width: 46ch;
    font-size: clamp(0.88rem, 2vw, 1rem);
    color: rgba(51, 51, 51, 0.6);
    line-height: 1.6;
  }

  /* ── Table wrapper ──────────────────────────────────── */
  .why-us__table-wrap {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  /* ── Table — no outer card, lives on the page background ── */
  .why-us__table {
    width: 100%;
    min-width: 320px;
    border-collapse: separate;
    border-spacing: 0;
    table-layout: fixed;
    /* No border, no box-shadow — the table is part of the page */
    border: none;
    background: transparent;
  }

  /* ── Column widths ──────────────────────────────────── */
  .why-us__th--feature,
  .why-us__td--feature {
    width: 52%;
  }
  .why-us__th--canijo,
  .why-us__td--canijo {
    width: 24%;
  }
  .why-us__th--competitor,
  .why-us__td--competitor {
    width: 24%;
  }

  /* ── Header row ─────────────────────────────────────── */
  .why-us__header-row {
    background: transparent;
  }

  .why-us__th {
    padding: 0;
    text-align: center;
    font-weight: 700;
    vertical-align: middle;
    /* No border on header cells by default */
    border: none;
  }

  /* Feature th — fully invisible, merges with section bg */
  .why-us__th--feature {
    background: transparent;
    border: none;
  }

  /* Brand th — top of the coral column panel */
  .why-us__th--canijo {
    background: var(--color-accent, #f86d4e);
    border-radius: 1.25rem 1.25rem 0 0;
    border: 2.5px solid #1a1a1a;
    border-bottom: none;
  }

  /* Competitor th — neutral top panel */
  .why-us__th--competitor {
    background: #fff;
    border-radius: 1.25rem 1.25rem 0 0;
    border: 2px solid rgba(26, 26, 26, 0.12);
    border-bottom: none;
  }

  /* ── Column header content ──────────────────────────── */
  .why-us__col-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1.1rem 0.75rem 1.25rem;
  }

  /* Brand logo image */
  .why-us__brand-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: clamp(5rem, 8vw, 7.5rem);
    height: clamp(5rem, 8vw, 7.5rem);
    padding: 0.2rem;
    border-radius: 50%;
    background: #fff;
    border: 2.5px solid #1a1a1a;
    box-shadow: 3px 3px 0px 0px #1a1a1a;
    text-decoration: none;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .why-us__brand-logo:hover {
    animation: wu-logo-bounce 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  .why-us__brand-logo img {
    width: 100%;
    height: 100%;
    display: block;
    border-radius: 50%;
    object-fit: contain;
  }

  .why-us__col-header--competitor {
    justify-content: center;
    min-height: 100%;
  }

  .why-us__col-name {
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: clamp(0.78rem, 2vw, 0.95rem);
    font-weight: 700;
    line-height: 1.25;
    text-align: center;
    color: rgba(51, 51, 51, 0.5);
  }

  /* ── Data rows ──────────────────────────────────────── */
  .why-us__row--odd {
    background: transparent;
  }
  .why-us__row--even {
    background: transparent;
  }

  /* ── Cells ──────────────────────────────────────────── */
  .why-us__td {
    padding: 0.85rem 0.75rem;
    vertical-align: middle;
    border: none;
  }

  /* Feature cell — transparent, just a horizontal divider */
  .why-us__td--feature {
    background: transparent;
    text-align: left;
    padding-left: 0;
    border-top: 1.5px solid rgba(26, 26, 26, 0.08);
  }

  /* Brand column — solid coral panel that runs unbroken */
  .why-us__td--canijo {
    text-align: center;
    background: rgba(248, 109, 78, 0.1);
    border-left: 2.5px solid #1a1a1a;
    border-right: 2.5px solid #1a1a1a;
    border-top: 1.5px solid rgba(26, 26, 26, 0.08);
  }

  /* Last brand cell — close the bottom of the panel */
  .why-us__row:last-child .why-us__td--canijo {
    border-bottom: 2.5px solid #1a1a1a;
    border-bottom-left-radius: 1rem;
    border-bottom-right-radius: 1rem;
  }

  /* Competitor column */
  .why-us__td--competitor {
    text-align: center;
    background: rgba(255, 255, 255, 0.55);
    border-left: 2px solid rgba(26, 26, 26, 0.1);
    border-right: 2px solid rgba(26, 26, 26, 0.1);
    border-top: 1.5px solid rgba(26, 26, 26, 0.08);
  }

  .why-us__row:last-child .why-us__td--competitor {
    border-bottom: 2px solid rgba(26, 26, 26, 0.1);
    border-bottom-left-radius: 1rem;
    border-bottom-right-radius: 1rem;
  }

  /* ── Feature label ──────────────────────────────────── */
  .why-us__feature-label {
    font-family: var(--font-body-family), 'Nunito Sans', sans-serif;
    font-size: clamp(0.85rem, 2vw, 0.95rem);
    font-weight: 600;
    color: var(--color-foreground, #333);
    line-height: 1.35;
  }

  /* ── Check / X badges ───────────────────────────────── */
  .why-us__check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: 2px solid #1a1a1a;
    font-weight: 700;
  }

  /* Brand yes — white check on coral bg */
  .why-us__td--canijo .why-us__check--yes {
    background: var(--color-accent, #f86d4e);
    color: #fff;
    box-shadow: 2px 2px 0px 0px #1a1a1a;
    /* Slightly more opaque so it pops off the tinted column bg */
    border-color: #1a1a1a;
  }

  /* Competitor yes — teal */
  .why-us__td--competitor .why-us__check--yes {
    background: var(--color-secondary, #0296b4);
    color: #fff;
    box-shadow: 2px 2px 0px 0px #1a1a1a;
  }

  .why-us__check--no {
    background: #fff;
    color: #ccc;
    border-color: #e0e0e0;
    box-shadow: none;
  }

  .why-us__check--text {
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-foreground, #333);
    width: auto;
    height: auto;
    border: none;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.05);
  }

  /* Pop animation when row enters viewport */
  .why-us__row.is-visible .why-us__check {
    animation: wu-check-pop 0.38s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }
  .why-us__row.is-visible:nth-child(1) .why-us__check {
    animation-delay: 0s;
  }
  .why-us__row.is-visible:nth-child(2) .why-us__check {
    animation-delay: 0.06s;
  }
  .why-us__row.is-visible:nth-child(3) .why-us__check {
    animation-delay: 0.12s;
  }
  .why-us__row.is-visible:nth-child(4) .why-us__check {
    animation-delay: 0.18s;
  }
  .why-us__row.is-visible:nth-child(5) .why-us__check {
    animation-delay: 0.24s;
  }
  .why-us__row.is-visible:nth-child(6) .why-us__check {
    animation-delay: 0.3s;
  }

  /* ── Screenreader util ──────────────────────────────── */
  .why-us__sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* ── CTA ────────────────────────────────────────────── */
  .why-us__cta-wrap {
    display: flex;
    justify-content: center;
    margin-top: clamp(1.75rem, 4vw, 2.5rem);
  }

  .why-us__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8rem 1.9rem;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: #fff;
    background: var(--color-accent, #f86d4e);
    border: 2.5px solid #1a1a1a;
    border-radius: 999px;
    box-shadow: 4px 5px 0px 0px #1a1a1a;
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .why-us__cta:hover {
    transform: translateY(-4px) scale(1.03);
    box-shadow: 6px 8px 0px 0px #1a1a1a;
  }

  .why-us__cta:hover svg {
    animation: wu-cta-arrow 0.5s ease-in-out infinite;
  }

  .why-us__cta:active {
    transform: translateY(1px);
    box-shadow: 2px 2px 0px 0px #1a1a1a;
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var rows = document.querySelectorAll('.why-us__row');
    if (!rows.length || !('IntersectionObserver' in window)) {
      rows.forEach(function (r) {
        r.classList.add('is-visible');
      });
      return;
    }
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.25, rootMargin: '0px 0px -40px 0px' }
    );
    rows.forEach(function (r) {
      observer.observe(r);
    });
  })();
{% endjavascript %}

