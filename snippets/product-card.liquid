{%- liquid
  assign p_price = product.price_min
  assign p_compare = product.compare_at_price_min
  assign p_onsale = false
  if p_compare > p_price
    assign p_onsale = true
  endif
  assign p_img = product.featured_image
  assign p_img2 = product.images[1]
-%}

<a class="{{ class_prefix }}__card-img-link" href="{{ product.url }}" tabindex="-1" aria-hidden="true">
  <div class="{{ class_prefix }}__card-img-wrap">
    {%- if p_onsale -%}
      <span class="{{ class_prefix }}__card-badge">Sale</span>
    {%- endif -%}

    {%- if p_img -%}
      <img
        class="{{ class_prefix }}__card-img {{ class_prefix }}__card-img--primary"
        src="{{ p_img | image_url: width: 600 }}"
        alt="{{ p_img.alt | escape | default: product.title }}"
        width="600"
        height="{{ 600 | divided_by: p_img.aspect_ratio | round }}"
        loading="lazy"
      >
      {%- if p_img2 -%}
        <img
          class="{{ class_prefix }}__card-img {{ class_prefix }}__card-img--secondary"
          src="{{ p_img2 | image_url: width: 600 }}"
          alt="{{ p_img2.alt | escape | default: product.title }}"
          width="600"
          height="{{ 600 | divided_by: p_img2.aspect_ratio | round }}"
          loading="lazy"
          aria-hidden="true"
        >
      {%- endif -%}
    {%- else -%}
      <div class="{{ class_prefix }}__card-img-ph" aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="34"
          height="34"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
        </svg>
      </div>
    {%- endif -%}
  </div>
</a>

<div class="{{ class_prefix }}__card-body">
  <div class="{{ class_prefix }}__card-info">
    <h3 class="{{ class_prefix }}__card-title">
      <a class="{{ class_prefix }}__card-title-link" href="{{ product.url }}">{{ product.title }}</a>
    </h3>
    <div class="{{ class_prefix }}__card-prices">
      <span class="{{ class_prefix }}__card-price{% if p_onsale %} is-sale{% endif %}">{{ p_price | money }}</span>
      {%- if p_onsale -%}
        <s class="{{ class_prefix }}__card-compare">{{ p_compare | money }}</s>
        {%- assign disc = p_compare | minus: p_price | times: 100 | divided_by: p_compare -%}
        <span class="{{ class_prefix }}__card-disc">-{{ disc }}%</span>
      {%- endif -%}
    </div>
    {%- unless product.available -%}
      <span class="{{ class_prefix }}__card-sold-out">Agotado</span>
    {%- endunless -%}
  </div>
  {%- if product.available -%}
    <div class="{{ class_prefix }}__card-actions">
      <form class="{{ class_prefix }}__quick-add" action="{{ routes.cart_add_url }}" method="post">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <button class="{{ class_prefix }}__quick-btn" type="submit" aria-label="Agregar {{ product.title }} al carrito">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          Agregar
        </button>
      </form>
    </div>
  {%- endif -%}
</div>
