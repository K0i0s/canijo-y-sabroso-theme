{% comment %}
  Predictive Search Overlay.
  Renders a full-screen modal positioned so the searchbar replaces the header bar.
  Usage: {% render 'predictive-search' %}
  Triggered by any element with [data-search-open].
{% endcomment %}

<div
  id="predictive-search-overlay"
  class="psearch"
  role="dialog"
  aria-modal="true"
  aria-label="Búsqueda"
  aria-hidden="true"
  hidden
>
  {{- '<!-- Backdrop -->' -}}
  <div class="psearch__backdrop" data-search-close></div>

  {{- '<!-- Top bar (replaces header visually) -->' -}}
  <div class="psearch__bar">
    <div class="psearch__shell">
      <form
        class="psearch__form"
        action="{{ routes.search_url }}"
        method="get"
        role="search"
        id="predictive-search-form"
      >
        <input type="hidden" name="type" value="product,article,page">

        <div class="psearch__input-wrap">
          <svg
            class="psearch__input-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="6.5"/><path d="M16 16L21 21"/>
          </svg>

          <input
            id="predictive-search-input"
            class="psearch__input"
            type="search"
            name="q"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            placeholder="Busca productos, páginas..."
            aria-label="Buscar"
            aria-autocomplete="list"
            aria-controls="predictive-search-results"
            aria-expanded="false"
          >

          <button
            id="predictive-search-clear"
            class="psearch__clear-btn"
            type="button"
            aria-label="Limpiar búsqueda"
            hidden
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              aria-hidden="true"
              width="16"
              height="16"
            >
              <path d="M18 6 6 18M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </form>

      <button
        class="psearch__close-btn"
        type="button"
        aria-label="Cerrar búsqueda"
        data-search-close
      >
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          aria-hidden="true"
          width="18"
          height="18"
        >
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
        Cerrar
      </button>
    </div>
  </div>

  {{- '<!-- Results panel -->' -}}
  <div class="psearch__panel">
    <div
      id="predictive-search-results"
      class="psearch__results"
      role="listbox"
      aria-label="Resultados de búsqueda"
    >
      {{- '<!-- Populated via JS -->' -}}
    </div>
  </div>
</div>

{% stylesheet %}
  /* ── Overlay shell ────────────────────────────────────────── */
  .psearch {
    position: fixed;
    inset: 0;
    z-index: 40;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .psearch[aria-hidden='false'] {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Backdrop ─────────────────────────────────────────────── */
  .psearch__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(26, 26, 26, 0.55);
    backdrop-filter: blur(3px);
    cursor: pointer;
  }

  /* ── Top bar ──────────────────────────────────────────────── */
  .psearch__bar {
    position: relative;
    z-index: 1;
    background: var(--color-light-cream, #fff6e5);
    border-bottom: 2.5px solid #1a1a1a;
    box-shadow: 0 4px 0px 0px #1a1a1a;
    padding: 0.65rem 0;
    min-height: 4.75rem;
    display: flex;
    align-items: center;
  }

  .psearch__shell {
    width: min(var(--page-width, 1200px), calc(100% - (var(--page-margin, 1.5rem) * 2)));
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* ── Form & input ─────────────────────────────────────────── */
  .psearch__form {
    flex: 1;
    min-width: 0;
  }

  .psearch__input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .psearch__input-icon {
    position: absolute;
    left: 0.9rem;
    width: 1.2rem;
    height: 1.2rem;
    color: rgba(51, 51, 51, 0.45);
    pointer-events: none;
    flex-shrink: 0;
  }

  .psearch__input {
    width: 100%;
    padding: 0.7rem 2.5rem 0.7rem 2.6rem;
    border-radius: 999px;
    border: 2.5px solid #1a1a1a;
    background: #fff;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-foreground, #333);
    box-shadow: 3px 3px 0 #1a1a1a;
    outline: none;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
    -webkit-appearance: none;
    appearance: none;
  }

  .psearch__input:focus {
    box-shadow: 4px 4px 0 var(--color-secondary, #0296b4);
    border-color: var(--color-secondary, #0296b4);
  }

  /* Remove native clear button from search input */
  .psearch__input::-webkit-search-decoration,
  .psearch__input::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }

  /* ── Clear button ─────────────────────────────────────────── */
  .psearch__clear-btn {
    position: absolute;
    right: 0.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6rem;
    height: 1.6rem;
    border-radius: 50%;
    border: 2px solid #1a1a1a;
    background: var(--color-accent, #f86d4e);
    color: #fff;
    cursor: pointer;
    transition: transform 0.15s ease, background 0.15s ease;
  }

  .psearch__clear-btn:hover {
    transform: scale(1.12);
    background: #d4553a;
  }

  /* ── Close button ─────────────────────────────────────────── */
  .psearch__close-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    border: 2.5px solid #1a1a1a;
    background: #fff;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 3px 3px 0 #1a1a1a;
    white-space: nowrap;
    flex-shrink: 0;
    transition: transform 0.15s ease, background 0.15s ease, color 0.15s ease;
  }

  .psearch__close-btn:hover {
    background: #1a1a1a;
    color: #fff;
    transform: translateY(-2px);
  }

  /* ── Results panel ────────────────────────────────────────── */
  .psearch__panel {
    position: relative;
    z-index: 1;
  }

  .psearch__results {
    background: #fff;
    border-bottom: 2.5px solid #1a1a1a;
    box-shadow: 0 4px 0 #1a1a1a;
    overflow: hidden;
  }

  /* ── Result groups ────────────────────────────────────────── */
  .psearch__group {
    padding: 0.75rem 0;
    border-bottom: 1.5px solid rgba(26, 26, 26, 0.08);
  }

  .psearch__group:last-child {
    border-bottom: none;
  }

  .psearch__group-title {
    padding: 0 1.25rem 0.4rem;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(51, 51, 51, 0.4);
  }

  /* ── Result items ─────────────────────────────────────────── */
  .psearch__item {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.6rem 1.25rem;
    text-decoration: none;
    color: var(--color-foreground, #333);
    transition: background 0.15s ease;
    cursor: pointer;
  }

  .psearch__item:hover,
  .psearch__item[aria-selected='true'] {
    background: var(--color-cream, #fcecc9);
  }

  .psearch__item-image {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.6rem;
    border: 2px solid #1a1a1a;
    object-fit: cover;
    flex-shrink: 0;
    background: var(--color-cream, #fcecc9);
  }

  .psearch__item-image-placeholder {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.6rem;
    border: 2px solid #1a1a1a;
    background: var(--color-cream, #fcecc9);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(51, 51, 51, 0.25);
    flex-shrink: 0;
  }

  .psearch__item-text {
    flex: 1;
    min-width: 0;
  }

  .psearch__item-title {
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .psearch__item-price {
    font-size: 0.8rem;
    color: var(--color-secondary, #0296b4);
    font-weight: 600;
  }

  .psearch__item-arrow {
    color: rgba(51, 51, 51, 0.3);
    flex-shrink: 0;
  }

  /* ── Query suggestion items ───────────────────────────────── */
  .psearch__item--query .psearch__item-icon {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.6rem;
    border: 2px solid #1a1a1a;
    background: var(--color-light-cream, #fff6e5);
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(51, 51, 51, 0.45);
    flex-shrink: 0;
  }

  /* ── "Search for [word]" button ───────────────────────────── */
  .psearch__submit-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.9rem 1.25rem;
    background: var(--color-foreground, #1a1a1a);
    color: #fff;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.15s ease;
  }

  .psearch__submit-btn:hover {
    background: var(--color-accent, #f86d4e);
  }

  .psearch__submit-btn-query {
    color: var(--color-accent, #f86d4e);
    font-style: italic;
  }

  /* ── Empty / loading state ────────────────────────────────── */
  .psearch__state {
    padding: 1.5rem 1.25rem;
    text-align: center;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 0.95rem;
    color: rgba(51, 51, 51, 0.5);
  }

  /* ── Hidden utility ───────────────────────────────────────── */
  .psearch [hidden] {
    display: none !important;
  }
{% endstylesheet %}

<script>
  (() => {
    const overlay = document.getElementById('predictive-search-overlay');
    const input = document.getElementById('predictive-search-input');
    const clearBtn = document.getElementById('predictive-search-clear');
    const results = document.getElementById('predictive-search-results');
    const form = document.getElementById('predictive-search-form');

    if (!overlay) return;

    // ── Open / Close ──────────────────────────────────────────
    const open = () => {
      overlay.removeAttribute('hidden');
      overlay.setAttribute('aria-hidden', 'false');
      document.documentElement.classList.add('psearch-open');
      requestAnimationFrame(() => input.focus());
    };

    const close = () => {
      overlay.setAttribute('aria-hidden', 'true');
      document.documentElement.classList.add('psearch-closing');
      setTimeout(() => {
        overlay.setAttribute('hidden', '');
        overlay.setAttribute('aria-hidden', 'true');
        document.documentElement.classList.remove('psearch-open', 'psearch-closing');
      }, 200);
    };

    // Triggers
    document.querySelectorAll('[data-search-open]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        open();
      });
    });
    document.querySelectorAll('[data-search-close]').forEach((el) => {
      el.addEventListener('click', close);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !overlay.hasAttribute('hidden')) close();
    });

    // ── Clear ─────────────────────────────────────────────────
    clearBtn.addEventListener('click', () => {
      input.value = '';
      clearBtn.setAttribute('hidden', '');
      input.setAttribute('aria-expanded', 'false');
      results.innerHTML = '';
      input.focus();
    });

    // ── Predictive fetch (debounced) ──────────────────────────
    let debounceTimer = null;
    let currentQuery = '';
    let abortController = null;

    const renderResults = (data, query) => {
      const { queries = [], pages = [], products = [] } = data?.resources?.results ?? {};
      let html = '';

      if (!queries.length && !pages.length && !products.length) {
        html = `<div class="psearch__state">Sin resultados para "<strong>${query}</strong>"</div>`;
        results.innerHTML = html;
        input.setAttribute('aria-expanded', 'false');
        return;
      }

      input.setAttribute('aria-expanded', 'true');

      // Query suggestions
      if (queries.length) {
        html += `<div class="psearch__group" role="group" aria-label="Sugerencias">
          <p class="psearch__group-title">Sugerencias</p>`;
        queries.slice(0, 4).forEach((q) => {
          html += `<a class="psearch__item psearch__item--query" href="{{ routes.search_url }}?q=${encodeURIComponent(
            q.text
          )}&type=product,article,page" role="option">
            <span class="psearch__item-icon" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><circle cx="11" cy="11" r="6.5"/><path d="M16 16L21 21"/></svg>
            </span>
            <span class="psearch__item-text">
              <span class="psearch__item-title">${q.styled_text || q.text}</span>
            </span>
            <svg class="psearch__item-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>`;
        });
        html += `</div>`;
      }

      // Pages
      if (pages.length) {
        html += `<div class="psearch__group" role="group" aria-label="Páginas">
          <p class="psearch__group-title">Páginas</p>`;
        pages.slice(0, 3).forEach((page) => {
          html += `<a class="psearch__item" href="${page.url}" role="option">
            <span class="psearch__item-image-placeholder" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            </span>
            <span class="psearch__item-text">
              <span class="psearch__item-title">${page.title}</span>
            </span>
            <svg class="psearch__item-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>`;
        });
        html += `</div>`;
      }

      // Products
      if (products.length) {
        html += `<div class="psearch__group" role="group" aria-label="Productos">
          <p class="psearch__group-title">Productos</p>`;
        products.slice(0, 4).forEach((product) => {
          const imgSrc = product.featured_image?.url ?? '';
          const price = product.price || '';
          const imgHtml = imgSrc
            ? `<img class="psearch__item-image" src="${imgSrc}&width=110" alt="${product.title}" width="55" height="55" loading="lazy">`
            : `<span class="psearch__item-image-placeholder" aria-hidden="true"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg></span>`;
          html += `<a class="psearch__item" href="${product.url}" role="option">
            ${imgHtml}
            <span class="psearch__item-text">
              <span class="psearch__item-title">${product.title}</span>
              ${price ? `<span class="psearch__item-price">${price}</span>` : ''}
            </span>
            <svg class="psearch__item-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>`;
        });
        html += `</div>`;
      }

      // "Search for [word]" CTA
      html += `<a class="psearch__submit-btn" href="{{ routes.search_url }}?q=${encodeURIComponent(
        query
      )}&type=product,article,page">
        Buscar <span class="psearch__submit-btn-query">"${query}"</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </a>`;

      results.innerHTML = html;
    };

    const fetchResults = async (query) => {
      if (!query.trim()) {
        results.innerHTML = '';
        input.setAttribute('aria-expanded', 'false');
        return;
      }

      if (abortController) abortController.abort();
      abortController = new AbortController();

      try {
        const jsonUrl = `/search/suggest.json?q=${encodeURIComponent(
          query
        )}&resources[type]=product,page,query&resources[limit]=4`;
        const response = await fetch(jsonUrl, { signal: abortController.signal });

        if (!response.ok) throw new Error(`Search API error: ${response.status}`);

        const data = await response.json();
        renderResults(data, query);
      } catch (err) {
        if (err.name === 'AbortError') return;
        results.innerHTML = `<div class="psearch__state">Error al buscar. Intenta de nuevo.</div>`;
      }
    };

    input.addEventListener('input', () => {
      const q = input.value.trim();
      clearBtn.toggleAttribute('hidden', q.length === 0);
      clearTimeout(debounceTimer);
      currentQuery = q;
      if (!q) {
        results.innerHTML = '';
        input.setAttribute('aria-expanded', 'false');
        return;
      }
      debounceTimer = setTimeout(() => fetchResults(q), 300);
    });

    // Allow form submit via Enter
    form.addEventListener('submit', (e) => {
      if (!input.value.trim()) e.preventDefault();
    });
  })();

  // Lock body scroll when search is open
  (() => {
    const style = document.createElement('style');
    style.textContent = `
      html.psearch-open body { overflow: hidden; }
    `;
    document.head.appendChild(style);
  })();
</script>
