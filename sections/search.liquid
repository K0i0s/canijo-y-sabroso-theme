{% comment %}
  Search results template.
  - Predictive-search style searchbar.
  - Neo-brutalist grid for products and articles.
  - Infinite scroll on mobile, pagination on desktop.
{% endcomment %}

<section class="search-page full-width" id="SearchSection" data-section-id="{{ section.id }}">
  <div class="search-page__inner">
    {{- '<!-- Header -->' -}}
    <h1 class="search-page__title">{{ 'search.title' | t }}</h1>

    {{- '<!-- Searchbar -->' -}}
    <form class="search-page__form" action="{{ routes.search_url }}" method="get" role="search">
      <input type="hidden" name="type" value="product,article">
      <input type="hidden" name="options[prefix]" value="last">

      <div class="search-page__input-wrap">
        <div class="search-page__input-field">
          <svg
            class="search-page__input-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="6.5"/><path d="M16 16L21 21"/>
          </svg>

          <input
            class="search-page__input"
            type="search"
            name="q"
            value="{{ search.terms | escape }}"
            placeholder="{{ 'search.placeholder' | t }}"
            aria-label="{{ 'search.title' | t }}"
          >
        </div>

        <button class="search-page__submit-btn" type="submit">
          {{ 'search.submit' | t }}
        </button>
      </div>
    </form>

    {{- '<!-- Results -->' -}}
    {% if search.performed %}
      {% if search.results_count == 0 %}
        <div class="search-page__empty-state">
          <svg
            class="search-page__empty-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="6.5"/><path d="M16 16L21 21"/>
            <line x1="1" y1="1" x2="23" y2="23" />
          </svg>
          <p>{{ 'search.no_results_html' | t: terms: search.terms }}</p>
        </div>
      {% else %}
        <div class="search-page__summary">
          <p>{{ 'search.results_count_html' | t: terms: search.terms, count: search.results_count }}</p>
        </div>

        {% paginate search.results by 12 %}
          <div class="search-page__grid" id="SearchGrid">
            {% for item in search.results %}
              {% case item.object_type %}
                {% when 'product' %}
                  <article class="sr__card">
                    {% render 'product-card', product: item, class_prefix: 'sr' %}
                  </article>
                {% when 'article' %}
                  <article class="sr__card search-page__article-card">
                    <a class="sr__card-img-link" href="{{ item.url }}" tabindex="-1" aria-hidden="true">
                      <div class="sr__card-img-wrap search-page__article-img-wrap">
                        {% if item.image %}
                          <img
                            class="sr__card-img sr__card-img--primary"
                            src="{{ item.image | image_url: width: 600 }}"
                            alt="{{ item.image.alt | default: item.title | escape }}"
                            width="600"
                            height="{{ 600 | divided_by: item.image.aspect_ratio | round }}"
                            loading="lazy"
                          >
                        {% else %}
                          <div class="sr__card-img-ph" aria-hidden="true">
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              width="34"
                              height="34"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="1.5"
                            >
                              <rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
                            </svg>
                          </div>
                        {% endif %}
                      </div>
                    </a>
                    <div class="sr__card-body search-page__article-body">
                      <div class="sr__card-info">
                        <h3 class="sr__card-title">
                          <a class="sr__card-title-link" href="{{ item.url }}">{{ item.title }}</a>
                        </h3>
                      </div>
                      <div class="search-page__article-cta">
                        <a href="{{ item.url }}" tabindex="-1">Leer más →</a>
                      </div>
                    </div>
                  </article>
                {% else %}
                  {% comment %} Skip pages as requested {% endcomment %}
              {% endcase %}
            {% endfor %}
          </div>

          {{- '<!-- Mobile Infinite Scroll Sentinel -->' -}}
          {% if paginate.next %}
            <div
              class="search-page__sentinel"
              data-search-infinite
              data-next-url="{{ paginate.next.url }}"
            >
              <div class="search-page__spinner"></div>
              <span class="visually-hidden">{{ 'search.load_more' | t }}</span>
            </div>
          {% endif %}

          {{- '<!-- Desktop Pagination -->' -}}
          {% if paginate.pages > 1 %}
            <nav class="search-page__pagination" aria-label="Paginación" data-desktop-pagination>
              {{ paginate | default_pagination }}
            </nav>
          {% endif %}
        {% endpaginate %}
      {% endif %}
    {% endif %}
  </div>
</section>

{% stylesheet %}
  /* ── Keyframes ──────────────────────────────────────── */
  @keyframes sp-shimmer {
    0% {
      background-position: -400px 0;
    }
    100% {
      background-position: 400px 0;
    }
  }

  @keyframes sp-spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* ── Section wrapper ────────────────────────────────── */
  .search-page {
    position: relative;
    background: var(--color-background, #fff6e5);
  }

  .search-page__inner {
    width: min(var(--page-width, 1200px), calc(100% - (var(--page-margin, 1.5rem) * 2)));
    margin: 0 auto;
    padding: clamp(3.5rem, 7vw, 5.5rem) 0;
  }

  /* ── Header ─────────────────────────────────────────── */
  .search-page__title {
    text-align: center;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    color: var(--color-foreground, #1a1a1a);
    margin: 0 0 2rem;
  }

  /* ── Searchbar (Matches predictive-search) ──────────── */
  .search-page__form {
    max-width: 700px;
    margin: 0 auto 3rem;
  }

  .search-page__input-wrap {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .search-page__input-field {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
  }

  .search-page__input-icon {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    left: 1.1rem;
    width: 1.3rem;
    height: 1.3rem;
    color: rgba(51, 51, 51, 0.45);
    pointer-events: none;
    z-index: 10;
  }

  .search-page__input {
    flex: 1;
    min-width: 0;
    min-height: 3.5rem;
    padding: 0.7rem 1.5rem 0.7rem 3rem;
    border-radius: 999px;
    border: 2.5px solid #1a1a1a;
    background: #fff;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-foreground, #333);
    box-shadow: 4px 4px 0 #1a1a1a;
    outline: none;
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
    -webkit-appearance: none;
    appearance: none;
  }

  .search-page__input:focus {
    box-shadow: 5px 5px 0 var(--color-secondary, #0296b4);
    border-color: var(--color-secondary, #0296b4);
  }

  .search-page__submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 1.5rem;
    min-height: 3.5rem;
    border-radius: 999px;
    border: 2.5px solid #1a1a1a;
    background: var(--color-accent, #f86d4e);
    color: #fff;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 4px 4px 0 #1a1a1a;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    white-space: nowrap;
  }

  .search-page__submit-btn:hover {
    background: #d4553a;
    transform: translateY(-2px);
    box-shadow: 5px 6px 0 #1a1a1a;
  }

  .search-page__submit-btn:active {
    transform: translateY(1px);
    box-shadow: 2px 2px 0 #1a1a1a;
  }

  @media screen and (max-width: 480px) {
    .search-page__input-wrap {
      flex-direction: column;
      align-items: stretch;
    }
    .search-page__submit-btn {
      width: 100%;
    }
  }

  /* ── Empty State ────────────────────────────────────── */
  .search-page__empty-state {
    text-align: center;
    padding: 4rem 1.25rem;
    background: #fff;
    border: 2.5px solid #1a1a1a;
    border-radius: 1.5rem;
    box-shadow: 5px 6px 0 #1a1a1a;
    max-width: 600px;
    margin: 0 auto;
  }

  .search-page__empty-state p {
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 1.2rem;
    color: rgba(51, 51, 51, 0.7);
    margin: 0;
  }

  .search-page__empty-icon {
    width: 3rem;
    height: 3rem;
    color: var(--color-accent, #f86d4e);
    margin-bottom: 1rem;
    opacity: 0.8;
  }

  /* ── Summary ────────────────────────────────────────── */
  .search-page__summary {
    margin-bottom: 2rem;
    text-align: center;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    color: rgba(51, 51, 51, 0.6);
  }

  /* ── Grid ───────────────────────────────────────────── */
  .search-page__grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.25rem;
  }

  @media screen and (min-width: 520px) {
    .search-page__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  @media screen and (min-width: 1100px) {
    .search-page__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.75rem;
    }
  }

  /* ── Product Card Prefix (sr__card) ─────────────────── */
  /* Replicating the fp__card logic */
  .sr__card {
    background: #fff;
    border: 2.5px solid #1a1a1a;
    border-radius: 1.25rem;
    box-shadow: 4px 4px 0 #1a1a1a;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s;
    height: 100%; /* For grid stretching */
  }

  .sr__card:hover {
    transform: translateY(-5px);
    box-shadow: 6px 7px 0 #1a1a1a;
  }

  .sr__card::before {
    content: '';
    display: block;
    height: 5px;
    background: var(--color-secondary, #0296b4);
  }

  .sr__card-img-link {
    display: block;
  }

  .sr__card-img-wrap {
    position: relative;
    padding-bottom: 90%;
    overflow: hidden;
    background: var(--color-cream, #fcecc9);
    border-bottom: 2px solid rgba(26, 26, 26, 0.06);
  }

  .sr__card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.38s ease, opacity 0.28s ease;
  }

  .sr__card-img--secondary {
    opacity: 0;
  }
  .sr__card:hover .sr__card-img--primary:not(:only-of-type) {
    opacity: 0;
  }
  .sr__card:hover .sr__card-img--secondary {
    opacity: 1;
    transform: scale(1.05);
  }
  .sr__card:hover .sr__card-img--primary:only-of-type {
    transform: scale(1.04);
  }

  .sr__card-img-ph {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(51, 51, 51, 0.2);
  }

  .sr__card-badge {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    z-index: 2;
    padding: 0.14rem 0.45rem;
    background: var(--color-accent, #f86d4e);
    color: #fff;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border: 2px solid #1a1a1a;
    border-radius: 999px;
  }

  .sr__quick-add {
    display: flex;
    align-items: center;
    margin: 0;
  }

  .sr__card:hover .sr__quick-add {
    transform: none;
    opacity: 1;
  }

  .sr__quick-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.32rem;
    padding: 0.42rem 0.9rem;
    background: var(--color-secondary, #0296b4);
    color: #fff;
    border: 2.5px solid #1a1a1a;
    border-radius: 999px;
    box-shadow: 2px 2px 0 #1a1a1a;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, transform 0.15s, box-shadow 0.15s;
  }

  .sr__quick-btn:hover,
  .sr__quick-btn.is-loading {
    background: var(--color-accent, #f86d4e);
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 3px 4px 0 #1a1a1a;
  }
  .sr__quick-btn.is-done {
    background: #22c55e;
    color: #fff;
  }

  .sr__card-body {
    padding: 0.8rem 0.95rem 0.95rem;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    flex: 1;
  }

  .sr__card-info {
    display: flex;
    flex-direction: column;
    gap: 0.32rem;
    flex: 1;
  }

  .sr__card-actions {
    flex-shrink: 0;
  }

  .sr__card-title {
    margin: 0;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: clamp(0.88rem, 2vw, 0.98rem);
    font-weight: 700;
    line-height: 1.25;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .sr__card-title-link {
    color: var(--color-foreground, #333);
    text-decoration: none;
  }
  .sr__card-title-link:hover {
    color: var(--color-secondary, #0296b4);
  }

  .sr__card-prices {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: auto;
  }

  .sr__card-price {
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-secondary, #0296b4);
  }

  .sr__card-price.is-sale {
    color: var(--color-accent, #f86d4e);
  }

  .sr__card-compare {
    font-size: 0.8rem;
    color: rgba(51, 51, 51, 0.38);
  }

  .sr__card-disc {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-accent, #f86d4e);
    padding: 0.08rem 0.32rem;
    background: rgba(248, 109, 78, 0.1);
    border-radius: 999px;
  }

  .sr__card-sold-out {
    font-size: 0.7rem;
    font-weight: 700;
    color: rgba(51, 51, 51, 0.38);
    letter-spacing: 0.04em;
  }

  /* ── Article Card Variants within Grid ──────────────── */
  .search-page__article-card::before {
    background: var(--color-accent, #f86d4e); /* Distinctive color for articles */
  }

  .search-page__article-img-wrap {
    /* Same aspect ratio as product cards */
    padding-bottom: 90%;
  }

  .search-page__article-body {
    flex-direction: column;
    align-items: flex-start;
  }

  .search-page__article-cta {
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .search-page__article-cta a {
    font-size: 0.82rem;
    font-weight: 700;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    color: var(--color-accent, #f86d4e);
    text-decoration: none;
    transition: letter-spacing 0.2s ease;
  }

  .sr__card:hover .search-page__article-cta a {
    letter-spacing: 0.04em;
  }

  /* ── Pagination ─────────────────────────────────────── */
  .search-page__pagination {
    margin-top: 3.5rem;
    display: flex;
    justify-content: center;
    gap: 0.5rem;
  }

  .search-page__pagination .pagination {
    display: flex;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
    justify-content: center;
  }

  .search-page__pagination .pagination li a,
  .search-page__pagination .pagination li span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    height: 2.5rem;
    padding: 0 0.75rem;
    border-radius: 0.75rem;
    border: 2px solid #1a1a1a;
    font-family: var(--font-heading-family), 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    color: var(--color-foreground, #1a1a1a);
    background: #fff;
    box-shadow: 3px 3px 0 #1a1a1a;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .search-page__pagination .pagination li a:hover {
    transform: translateY(-2px);
    box-shadow: 4px 5px 0 #1a1a1a;
  }

  .search-page__pagination .pagination li span.current {
    background: var(--color-accent, #f86d4e);
    color: #fff;
    border-color: #1a1a1a;
  }

  /* ── Infinite Scroll Sentinel ───────────────────────── */
  .search-page__sentinel {
    display: none;
    padding: 3rem 0;
    justify-content: center;
  }

  .search-page__spinner {
    width: 2.5rem;
    height: 2.5rem;
    border: 4px solid var(--color-cream, #fcecc9);
    border-top-color: var(--color-secondary, #0296b4);
    border-radius: 50%;
    animation: sp-spin 1s linear infinite;
  }

  /* ── Desktop vs Mobile Display Logic ────────────────── */
  @media screen and (min-width: 768px) {
    /* Desktop: Use pagination, hide sentinel */
    .search-page__sentinel {
      display: none !important;
    }
  }

  @media screen and (max-width: 767px) {
    /* Mobile: Hide pagination, show sentinel if next page exists */
    .search-page__pagination {
      display: none !important;
    }

    .search-page__sentinel[data-next-url] {
      display: flex;
    }
  }
{% endstylesheet %}

<script>
  (() => {
    const sentinel = document.querySelector('[data-search-infinite]');
    const grid = document.getElementById('SearchGrid');

    if (!sentinel || !grid) return;

    let isLoading = false;
    let observer = null;

    const loadNextPage = async (url) => {
      if (isLoading) return;
      isLoading = true;

      try {
        const response = await fetch(url);
        if (!response.ok) throw new Error('Network response was not ok');

        const html = await response.text();
        const parser = new DOMParser();
        const doc = parser.parseFromString(html, 'text/html');

        // Extract new items
        const newItems = doc.querySelectorAll('#SearchGrid > article');
        if (newItems.length > 0) {
          newItems.forEach((item) => grid.appendChild(item));
        }

        // Update URL for next fetch
        const newSentinel = doc.querySelector('[data-search-infinite]');
        if (newSentinel && newSentinel.dataset.nextUrl) {
          sentinel.dataset.nextUrl = newSentinel.dataset.nextUrl;
        } else {
          // No more pages
          sentinel.removeAttribute('data-next-url');
          sentinel.style.display = 'none';
          if (observer) observer.disconnect();
        }

        // Re-init quick add event listeners or components if needed
        // (Our quick-add script handles this globally via form submission bubbling)
      } catch (error) {
        console.error('Error loading more results:', error);
      } finally {
        isLoading = false;
      }
    };

    const handleIntersection = (entries) => {
      // Only process infinite scroll on mobile (< 768px)
      if (window.innerWidth >= 768) return;

      const entry = entries[0];
      if (entry.isIntersecting && sentinel.dataset.nextUrl) {
        loadNextPage(sentinel.dataset.nextUrl);
      }
    };

    observer = new IntersectionObserver(handleIntersection, {
      rootMargin: '200px', // Load before reaching the very end
      threshold: 0,
    });

    observer.observe(sentinel);

    // Stop observing if window is resized past mobile breakpoint
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768) {
        // Desktop handles it normally, we just hide sentinel via CSS
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Search Results",
  "settings": []
}
{% endschema %}
