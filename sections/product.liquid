    padding: clamp(2rem, 4vw, 3.5rem) 0 clamp(3rem, 6vw, 5rem);
  }

  .pdp__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.25rem;
  }

  @media screen and (min-width: 750px) {
    .pdp__layout {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 3rem;
      align-items: start;
    }
  }

  @media screen and (min-width: 1100px) {
