{% comment %}
  Product page — Canijo y Sabroso theme
  Full toyful design: bold borders, offset shadows, Fredoka, orange/teal palette.
{% endcomment %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign compare_price = current_variant.compare_at_price
  assign current_price = current_variant.price
  assign on_sale = false
  if compare_price > current_price
    assign on_sale = true
  endif
  assign low_stock_threshold = 20
  assign show_stock_warning = false
  if current_variant.inventory_management == 'shopify' and current_variant.inventory_quantity > 0 and current_variant.inventory_quantity < low_stock_threshold
    assign show_stock_warning = true
  endif
  assign rating_value = product.metafields.reviews.rating.value | default: 0
  assign rating_count = product.metafields.reviews.rating_count.value | default: 0
  assign has_multiple_variants = false
  if product.variants.size > 1
    assign has_multiple_variants = true
  endif
-%}

<div class="pdp full-width">
  {{- '<!-- Bg texture -->' -}}
  <div class="pdp__bg-texture" aria-hidden="true"></div>

  <div class="pdp__inner">
    <div class="pdp__layout">
      {{- '<!--════════════ GALLERY ════════════-->' -}}
      <div class="pdp__gallery" id="pdp-gallery">
        {{- '<!-- Main image -->' -}}
        <div class="pdp__main-image-wrap" id="pdp-main-wrap">
          {%- if on_sale -%}
            <div class="pdp__sale-badge" aria-label="En oferta">Sale</div>
          {%- endif -%}

          {%- if product.featured_image -%}
            <img
              id="pdp-main-img"
              class="pdp__main-image"
              src="{{ product.featured_image | image_url: width: 900 }}"
              alt="{{ product.featured_image.alt | escape | default: product.title }}"
              width="900"
              height="{{ 900 | divided_by: product.featured_image.aspect_ratio | round }}"
              loading="eager"
            >
          {%- else -%}
            <div class="pdp__image-placeholder" aria-label="Sin imagen">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="48"
                height="48"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
              >
                <rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/>
              </svg>
            </div>
          {%- endif -%}

          {{- '<!-- Image shine overlay -->' -}}
          <div class="pdp__image-shine" aria-hidden="true"></div>
        </div>

        {{- '<!-- Thumbnails -->' -}}
        {%- if product.images.size > 1 -%}
          <div class="pdp__thumbs" id="pdp-thumbs" role="list" aria-label="Imágenes del producto">
            {%- for image in product.images -%}
              <button
                class="pdp__thumb{% if forloop.first %} pdp__thumb--active{% endif %}"
                data-src="{{ image | image_url: width: 900 }}"
                data-alt="{{ image.alt | escape | default: product.title }}"
                data-index="{{ forloop.index0 }}"
                role="listitem"
                aria-label="Ver imagen {{ forloop.index }}"
                type="button"
              >
                <img
                  src="{{ image | image_url: width: 160 }}"
                  alt="{{ image.alt | escape | default: product.title }}"
                  width="80"
                  height="80"
                  loading="lazy"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      {{- '<!-- /gallery -->' -}}

      {{- '<!--════════════ INFO PANEL ════════════-->' -}}
      <div class="pdp__info">
        {{- '<!-- Brand eyebrow -->' -}}
        <div class="pdp__eyebrow">
          {{ product.vendor | default: 'Canijo y Sabroso' }}
        </div>

        {{- '<!-- Product title -->' -}}
        <h1 class="pdp__title">{{ product.title }}</h1>

        {{- '<!-- Star rating -->' -}}
        {%- if rating_value > 0 -%}
          <div class="pdp__rating" aria-label="{{ rating_value | round: 1 }} de 5 estrellas">
            {%- assign full_stars = rating_value | floor -%}
            {%- assign empty_stars = 5 | minus: full_stars -%}
            <div class="pdp__stars" aria-hidden="true">
              {%- for i in (1..full_stars) -%}
                <svg class="pdp__star pdp__star--full" viewBox="0 0 20 20" fill="currentColor">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.953a1 1 0 00.95.69h4.162c.969 0 1.372 1.24.588 1.81l-3.368 2.448a1 1 0 00-.364 1.118l1.286 3.953c.3.921-.755 1.688-1.54 1.118L10 15.347l-3.951 2.87c-.784.57-1.838-.197-1.539-1.118l1.286-3.953a1 1 0 00-.364-1.118L2.064 9.38c-.784-.57-.38-1.81.588-1.81h4.162a1 1 0 00.951-.69l1.284-3.953z"/>
                </svg>
              {%- endfor -%}
              {%- for i in (1..empty_stars) -%}
                <svg
                  class="pdp__star pdp__star--empty"
                  viewBox="0 0 20 20"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.953a1 1 0 00.95.69h4.162c.969 0 1.372 1.24.588 1.81l-3.368 2.448a1 1 0 00-.364 1.118l1.286 3.953c.3.921-.755 1.688-1.54 1.118L10 15.347l-3.951 2.87c-.784.57-1.838-.197-1.539-1.118l1.286-3.953a1 1 0 00-.364-1.118L2.064 9.38c-.784-.57-.38-1.81.588-1.81h4.162a1 1 0 00.951-.69l1.284-3.953z"/>
                </svg>
              {%- endfor -%}
            </div>
            <span class="pdp__rating-count">({{ rating_count }} reseñas)</span>
          </div>
        {%- endif -%}

        {{- '<!-- Price block -->' -}}
        <div class="pdp__price-block" id="pdp-price">
          <span class="pdp__price{% if on_sale %} pdp__price--sale{% endif %}">
            {{ current_price | money }}
          </span>
          {%- if on_sale -%}
            <s class="pdp__compare-price">{{ compare_price | money }}</s>
            {%- assign pct = compare_price | minus: current_price | times: 100 | divided_by: compare_price -%}
            <span class="pdp__discount-badge">-{{ pct }}%</span>
          {%- endif -%}
        </div>

        {{- '<!-- Stock urgency bar -->' -}}
        {%- if show_stock_warning -%}
          <div class="pdp__stock-alert" id="pdp-stock" role="status" aria-live="polite">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
            <span
              >¡Solo quedan <strong>{{ current_variant.inventory_quantity }}</strong> en stock!</span
            >
          </div>
        {%- endif -%}

        {{- '<!-- Product form -->' -}}
        {%- form 'product', product, id: 'pdp-form', class: 'pdp__form' -%}
          {{- '<!-- Variant selector -->' -}}
          {%- if has_multiple_variants -%}
            <div class="pdp__variants" id="pdp-variants">
              {%- for option in product.options_with_values -%}
                <div class="pdp__option-group">
                  <p class="pdp__option-label">{{ option.name }}</p>
                  <div class="pdp__option-pills" role="group" aria-label="{{ option.name }}">
                    {%- for value in option.values -%}
                      <label class="pdp__pill-label">
                        <input
                          class="pdp__pill-input"
                          type="radio"
                          name="option-{{ option.position }}"
                          value="{{ value }}"
                          {% if option.selected_value == value %}
                            checked
                          {% endif %}
                          data-option-position="{{ option.position }}"
                        >
                        <span class="pdp__pill-text">{{ value }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}

              {{- '<!-- Hidden variant id input (updated by JS) -->' -}}
              <input type="hidden" name="id" id="pdp-variant-id" value="{{ current_variant.id }}">
            </div>
          {%- else -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}">
          {%- endif -%}

          {{- '<!-- Quantity stepper -->' -}}
          <div class="pdp__qty-row">
            <label class="pdp__qty-label" for="pdp-qty">Cantidad</label>
            <div class="pdp__qty-stepper" role="group" aria-label="Cantidad">
              <button
                class="pdp__qty-btn"
                type="button"
                id="pdp-qty-minus"
                aria-label="Reducir cantidad"
                data-action="minus"
              >
                −
              </button>
              <input
                class="pdp__qty-input"
                id="pdp-qty"
                type="number"
                name="quantity"
                value="1"
                min="1"
                {% if current_variant.inventory_management == 'shopify' %}
                  max="{{ current_variant.inventory_quantity }}"
                {% endif %}
                aria-label="Cantidad"
              >
              <button
                class="pdp__qty-btn"
                type="button"
                id="pdp-qty-plus"
                aria-label="Aumentar cantidad"
                data-action="plus"
              >
                +
              </button>
            </div>
          </div>

          {{- '<!-- CTA buttons -->' -}}
          <div class="pdp__cta-group">
            <button
              class="pdp__btn pdp__btn--cart"
              type="submit"
              name="add"
              id="pdp-add-to-cart"
              {% unless current_variant.available %}
                disabled
              {% endunless %}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                aria-hidden="true"
              >
                <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/>
                <path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/>
              </svg>
              {%- if current_variant.available -%}
                Agregar al carrito
              {%- else -%}
                Agotado
              {%- endif -%}
            </button>

            <div class="pdp__btn-buy-wrap">
              {{ form | payment_button }}
            </div>
          </div>
        {%- endform -%}

        {{- '<!-- Trust chips -->' -}}
        <div class="pdp__trust">
          <div class="pdp__trust-item">
            <span class="pdp__trust-icon" aria-hidden="true">🌿</span>
            <span>100% natural</span>
          </div>
          <div class="pdp__trust-item">
            <span class="pdp__trust-icon" aria-hidden="true">🚫</span>
            <span>Sin conservadores</span>
          </div>
          <div class="pdp__trust-item">
            <span class="pdp__trust-icon" aria-hidden="true">🇲🇽</span>
            <span>Hecho en México</span>
          </div>
          <div class="pdp__trust-item">
            <span class="pdp__trust-icon" aria-hidden="true">🚚</span>
            <span>Envío rápido</span>
          </div>
        </div>

        {{- '<!-- Share button -->' -}}
        <div class="pdp__share-wrap">
          <button class="pdp__share-btn" id="pdp-share" type="button" aria-label="Compartir producto">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              aria-hidden="true"
            >
              <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
              <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
            </svg>
            Compartir
          </button>
          <span class="pdp__share-confirm" id="pdp-share-confirm" aria-live="polite" hidden>¡Enlace copiado! 🐾</span>
        </div>

        {{- '<!-- Accordion: Description / Ingredients / Nutrition -->' -}}
        <div class="pdp__accordions">
          {{- '<!-- Description -->' -}}
          <details class="pdp__accordion" open>
            <summary class="pdp__accordion-trigger">
              <span class="pdp__accordion-icon" aria-hidden="true">📝</span>
              <span>Descripción</span>
              <svg
                class="pdp__accordion-chevron"
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                aria-hidden="true"
              >
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </summary>
            <div class="pdp__accordion-body rte">
              {{ product.description }}
            </div>
          </details>

          {{- '<!-- Ingredients (metafield) -->' -}}
          {%- if product.metafields.custom.ingredients != blank -%}
            <details class="pdp__accordion">
              <summary class="pdp__accordion-trigger">
                <span class="pdp__accordion-icon" aria-hidden="true">🌿</span>
                <span>Ingredientes</span>
                <svg
                  class="pdp__accordion-chevron"
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  aria-hidden="true"
                >
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </summary>
              <div class="pdp__accordion-body">
                <p class="pdp__ingredients-text">{{ product.metafields.custom.ingredients }}</p>
              </div>
            </details>
          {%- endif -%}

          {{- '<!-- Nutrition facts (metafield) -->' -}}
          {%- if product.metafields.custom.nutrition_facts != blank -%}
            <details class="pdp__accordion">
              <summary class="pdp__accordion-trigger">
                <span class="pdp__accordion-icon" aria-hidden="true">💪</span>
                <span>Información Nutricional</span>
                <svg
                  class="pdp__accordion-chevron"
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  aria-hidden="true"
                >
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </summary>
              <div class="pdp__accordion-body">
                <div class="pdp__nutrition-table">
                  <div class="pdp__nutrition-header">
                    <span>Información Nutricional</span>
                    <span class="pdp__nutrition-serving">
                      {{- product.metafields.custom.serving_size | default: 'por 100g' -}}
                    </span>
                  </div>
                  <div class="pdp__nutrition-body rte">
                    {{ product.metafields.custom.nutrition_facts }}
                  </div>
                </div>
              </div>
            </details>
          {%- endif -%}

          {{- '<!-- Shipping (always shown) -->' -}}
          <details class="pdp__accordion">
            <summary class="pdp__accordion-trigger">
              <span class="pdp__accordion-icon" aria-hidden="true">🚚</span>
              <span>Envío y devoluciones</span>
              <svg
                class="pdp__accordion-chevron"
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                aria-hidden="true"
              >
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </summary>
            <div class="pdp__accordion-body">
              <p>
                Enviamos a toda la República Mexicana. Los pedidos se procesan en 1–2 días hábiles. Si tienes algún
                problema con tu pedido, contáctanos y lo resolvemos sin complicaciones.
              </p>
            </div>
          </details>
        </div>
        {{- '<!-- /accordions -->' -}}
      </div>
      {{- '<!-- /info -->' -}}
    </div>
    {{- '<!-- /layout -->' -}}
  </div>
  {{- '<!-- /inner -->' -}}
</div>
{{- '<!-- /pdp -->' -}}

<script>
  (function () {
    // ── Gallery image switcher ───────────────────────────────
    const thumbs = document.querySelectorAll('.pdp__thumb');
    const mainImg = document.getElementById('pdp-main-img');

    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        if (!mainImg) return;

        // Fade out
        mainImg.style.opacity = '0';
        mainImg.style.transform = 'scale(0.97)';

        setTimeout(() => {
          mainImg.src = thumb.dataset.src;
          mainImg.alt = thumb.dataset.alt || '';
          // Fade in
          mainImg.style.opacity = '1';
          mainImg.style.transform = 'scale(1)';
        }, 160);

        thumbs.forEach((t) => t.classList.remove('pdp__thumb--active'));
        thumb.classList.add('pdp__thumb--active');
      });
    });

    // ── Quantity stepper ─────────────────────────────────────
    const qtyInput = document.getElementById('pdp-qty');
    const minusBtn = document.getElementById('pdp-qty-minus');
    const plusBtn = document.getElementById('pdp-qty-plus');

    function updateQty(delta) {
      if (!qtyInput) return;
      const current = parseInt(qtyInput.value, 10) || 1;
      const min = parseInt(qtyInput.min, 10) || 1;
      const max = parseInt(qtyInput.max, 10) || 999;
      const next = Math.min(Math.max(current + delta, min), max);
      qtyInput.value = next;

      // Animate input
      qtyInput.style.transform = 'scale(1.15)';
      setTimeout(() => {
        qtyInput.style.transform = 'scale(1)';
      }, 150);

      if (minusBtn) minusBtn.disabled = next <= min;
      if (plusBtn) plusBtn.disabled = next >= max;
    }

    if (minusBtn) {
      minusBtn.disabled = true; // starts at 1
      minusBtn.addEventListener('click', () => updateQty(-1));
    }
    if (plusBtn) plusBtn.addEventListener('click', () => updateQty(1));

    // ── Variant selector ─────────────────────────────────────
    const variantInputs = document.querySelectorAll('.pdp__pill-input');
    const variantIdInput = document.getElementById('pdp-variant-id');
    const priceBlock = document.getElementById('pdp-price');
    const addToCart = document.getElementById('pdp-add-to-cart');
    const stockAlert = document.getElementById('pdp-stock');

    if (variantInputs.length && variantIdInput) {
      variantInputs.forEach((input) => {
        input.addEventListener('change', () => {
          // Build selected options map
          const selectedOptions = {};
          document.querySelectorAll('.pdp__pill-input:checked').forEach((checked) => {
            selectedOptions['option' + checked.dataset.optionPosition] = checked.value;
          });

          // Find matching variant via Shopify JS (product JSON)
          fetch(window.location.pathname + '.js')
            .then((res) => res.json())
            .then((data) => {
              const match = data.variants.find((v) => {
                return Object.keys(selectedOptions).every((key) => {
                  const pos = parseInt(key.replace('option', ''), 10);
                  return v['option' + pos] === selectedOptions[key];
                });
              });

              if (!match) return;

              variantIdInput.value = match.id;

              // Update price display
              if (priceBlock) {
                const priceEl = priceBlock.querySelector('.pdp__price');
                const compareEl = priceBlock.querySelector('.pdp__compare-price');
                const badgeEl = priceBlock.querySelector('.pdp__discount-badge');
                const fmt = (cents) => '$' + (cents / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',') + ' MXN';

                if (priceEl) priceEl.textContent = fmt(match.price);

                if (match.compare_at_price && match.compare_at_price > match.price) {
                  if (compareEl) compareEl.textContent = fmt(match.compare_at_price);
                  else {
                    const s = document.createElement('s');
                    s.className = 'pdp__compare-price';
                    s.textContent = fmt(match.compare_at_price);
                    priceEl.after(s);
                  }
                } else {
                  if (compareEl) compareEl.remove();
                  if (badgeEl) badgeEl.remove();
                }
              }

              // Update add to cart availability
              if (addToCart) {
                addToCart.disabled = !match.available;
                addToCart.querySelector('span') ||
                  (addToCart.lastChild.textContent = match.available ? 'Agregar al carrito' : 'Agotado');
              }

              // Update qty max
              if (qtyInput && match.inventory_management === 'shopify') {
                qtyInput.max = match.inventory_quantity;
              }
            })
            .catch(() => {});
        });
      });
    }

    // ── Share button ─────────────────────────────────────────
    const shareBtn = document.getElementById('pdp-share');
    const shareConfirm = document.getElementById('pdp-share-confirm');

    if (shareBtn) {
      shareBtn.addEventListener('click', () => {
        const shareData = {
          title: document.title,
          url: window.location.href,
        };

        if (navigator.share && navigator.canShare && navigator.canShare(shareData)) {
          navigator.share(shareData).catch(() => {});
        } else {
          // Fallback: copy to clipboard
          navigator.clipboard
            .writeText(window.location.href)
            .then(() => {
              if (shareConfirm) {
                shareConfirm.hidden = false;
                setTimeout(() => {
                  shareConfirm.hidden = true;
                }, 2500);
              }
            })
            .catch(() => {});
        }

        // Bounce animation
        shareBtn.style.transform = 'scale(0.92)';
        setTimeout(() => {
          shareBtn.style.transform = 'scale(1)';
        }, 180);
      });
    }

    // ── Accordion smooth height animation ───────────────────
    document.querySelectorAll('.pdp__accordion').forEach((details) => {
      const summary = details.querySelector('summary');
      const body = details.querySelector('.pdp__accordion-body');
      if (!summary || !body) return;

      summary.addEventListener('click', (e) => {
        e.preventDefault();
        if (details.open) {
          body.style.maxHeight = body.scrollHeight + 'px';
          requestAnimationFrame(() => {
            body.style.maxHeight = '0';
            body.style.opacity = '0';
          });
          setTimeout(() => {
            details.open = false;
          }, 300);
        } else {
          details.open = true;
          body.style.maxHeight = '0';
          body.style.opacity = '0';
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              body.style.maxHeight = body.scrollHeight + 'px';
              body.style.opacity = '1';
            });
          });
          setTimeout(() => {
            body.style.maxHeight = 'none';
          }, 310);
        }
      });
    });

    // ── Add to Cart (AJAX + Drawer) ─────────────────────────
    const productForm = document.getElementById('pdp-form');
    if (productForm && addToCart) {
      productForm.addEventListener('submit', (e) => {
        e.preventDefault();

        const prevText = addToCart.lastChild.textContent;
        addToCart.disabled = true;
        addToCart.lastChild.textContent = 'Agregando...';

        const formData = new FormData(productForm);

        fetch((window.Shopify?.routes?.root || '/') + 'cart/add.js', {
          method: 'POST',
          headers: {
            'X-Requested-With': 'XMLHttpRequest',
          },
          body: formData,
        })
          .then((res) => {
            if (!res.ok) throw new Error('Error agregando al carrito');
            return res.json();
          })
          .then(() => {
            // Trigger drawer update rendering
            document.dispatchEvent(new CustomEvent('cart:updated'));

            // Open drawer
            if (window.__cartDrawer) {
              window.__cartDrawer.open();
            }
          })
          .catch((err) => {
            console.error(err);
            alert('Hubo un error intentando agregar este producto al carrito.');
          })
          .finally(() => {
            addToCart.disabled = false;
            addToCart.lastChild.textContent = prevText;
          });
      });
    }
  })();
</script>

{% stylesheet %}
  /* ── Keyframes ──────────────────────────────────────── */
  @keyframes pdp-pop-in {
    from {
      opacity: 0;
      transform: translateY(22px) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes pdp-slide-in {
    from {
      opacity: 0;
      transform: translateX(24px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @keyframes pdp-star-blink {
    0%,
    100% {
      opacity: 0.45;
      transform: scale(1) rotate(var(--r, 0deg));
    }
    50% {
      opacity: 0.85;
      transform: scale(1.35) rotate(var(--r, 0deg));
    }
  }

  @keyframes pdp-stock-flash {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.6;
    }
  }

  @keyframes pdp-cart-bounce {
